<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Navegacao inteligente no aeroporto. Planeje sua rota antes de chegar." />
  <title>SkyGate - Planeje sua rota</title>

  <link rel="icon" type="image/jpeg" href="assets/logo.jpeg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            heading: ['Plus Jakarta Sans', 'ui-sans-serif', 'system-ui'],
            mono: ['Space Mono', 'monospace'],
          },
          colors: {
            navy: {
              50: '#f0f4f8', 100: '#d9e2ec', 200: '#bcccdc', 300: '#9fb3c8',
              400: '#829ab1', 500: '#627d98', 600: '#486581', 700: '#334e68',
              800: '#243b53', 900: '#102a43', 950: '#0a192f',
            },
            teal: {
              50: '#f0fdfa', 100: '#ccfbf1', 200: '#99f6e4', 300: '#5eead4',
              400: '#2dd4bf', 500: '#14b8a6', 600: '#0d9488', 700: '#0f766e',
            },
            gold: {
              100: '#fef3c7', 200: '#fde68a', 300: '#fcd34d',
              400: '#fbbf24', 500: '#f59e0b', 600: '#d97706',
            },
          },
          boxShadow: {
            soft: '0 2px 12px rgba(0,0,0,0.06)',
            card: '0 1px 4px rgba(0,0,0,0.04), 0 4px 20px rgba(0,0,0,0.06)',
          },
        },
      },
    };
  </script>
  <style>
    .map-route-line {
      stroke-dasharray: 6 5;
      animation: route-dash 1.2s linear infinite;
    }

    @keyframes route-dash {
      from { stroke-dashoffset: 20; }
      to { stroke-dashoffset: 0; }
    }
  </style>
</head>
<body class="bg-slate-50 text-navy-950 font-sans antialiased">
  <main></main>
  <script type="module" src="app.js"></script>
</body>
</html>