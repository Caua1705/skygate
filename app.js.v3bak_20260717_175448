/* ============================================================
   3. HELPERS
   ============================================================ */

function asArray(v) {
  if (Array.isArray(v)) return v;
  if (Array.isArray(v?.items))    return v.items;
  if (Array.isArray(v?.data))     return v.data;
  if (Array.isArray(v?.airports)) return v.airports;
  if (Array.isArray(v?.nodes))    return v.nodes;
  return [];
}

function first(...vals) {
  return vals.find(v => v !== undefined && v !== null && v !== '');
}

function esc(v) {
  return String(v ?? '').replace(/[&<>"']/g, c => (
    {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]
  ));
}

function norm(v) {
  return String(v ?? '').normalize('NFD')
    .replace(/[\u0300-\u036f]/g,'').toLowerCase().trim();
}

function fmtMin(m) { return String(Math.max(1, Math.round(Number(m)||0))); }

function getFloorLabel(id) {
  const s = String(id ?? '');
  return FLOOR_LABELS[s] ?? appData.floors.find(f=>f.id===s)?.name ?? `Piso ${s}`;
}

function getNodeMeta(type) {
  return NODE_META[String(type||'').toLowerCase()] ?? {
    label:'Ponto', icon:'solar:map-point-bold', color:'#94a3b8', group:'OUTROS',
  };
}

function getAirportSlug(a) {
  return first(a?.slug, a?.code, a?.id, FORTALEZA_SLUG);
}

function findNode(code) {
  return appData.nodes.find(n => n.code === code) ?? null;
}

function getModeLabel(m) {
  return m === 'accessible' ? 'Acessível' : 'Mais rápida';
}

function getFloorTransform(floorId) {
  return mapState.floorTransforms[floorId] ?? { x:0, y:0, scale:1 };
}

/* ============================================================
   4. DATA NORMALIZATION
   ============================================================ */

function normalizeMap(raw) {
  const rawNodes = asArray(raw?.nodes ?? raw?.points ?? raw?.data?.nodes);

  const nodes = rawNodes.map((r, i) => {
    const code   = String(first(r?.node_code, r?.code, r?.id, `n${i}`));
    const floorId= String(first(r?.floor, r?.floor_id, r?.level, '0'));
    const type   = String(first(r?.type, r?.category, r?.kind, 'waypoint')).toLowerCase();
    const name   = first(r?.display_name, r?.name, r?.label, r?.title, code);
    return {
      code, floorId, type, name,
      searchText: norm(`${name} ${getNodeMeta(type).label}`),
      isPoi: POI_TYPES.has(type) && !INTERNAL_TYPES.has(type),
      x: Number(first(r?.x, r?.position_x, 0)),
      y: Number(first(r?.y, r?.position_y, 0)),
    };
  });

  const floorIds = [...new Set(
    rawNodes.map(n=>String(n?.floor??'')).filter(Boolean)
  )].sort();

  const floors = (floorIds.length ? floorIds
    : [...new Set(nodes.map(n=>n.floorId))].sort()
  ).map(id => ({ id, name: FLOOR_LABELS[id] ?? `Piso ${id}` }));

  return { floors, nodes };
}

function normalizeRoute(raw) {
  const rawSegs = raw?.floor_segments ?? raw?.floorSegments;
  let segments = Array.isArray(rawSegs)
    ? rawSegs.map(normalizeSeg).filter(Boolean)
    : [];

  const path = extractCodes(raw);
  if (!segments.length && path.length) segments = buildSegments(path);

  const rawSteps = asArray(raw?.steps ?? raw?.instructions ?? raw?.directions);
  const steps = rawSteps.map((s, i) => normalizeStep(s, i));

  const estimatedMinutes = Number(
    first(raw?.total_estimated_time_minutes, raw?.estimated_time_minutes, 0)
  );

  return {
    raw,
    estimatedMinutes: Number.isFinite(estimatedMinutes) ? estimatedMinutes : 0,
    path,
    segments,
    steps,
    warnings: asArray(raw?.warnings),
  };
}

function normalizeSeg(s) {
  if (!s || typeof s !== 'object') return null;
  if (s.transition && typeof s.transition === 'object') {
    return {
      type: 'transition',
      transitionType: String(first(s.transition.type, 'transition')),
      fromFloor: String(first(s.transition.from_floor, s.transition.fromFloor, '')),
      toFloor:   String(first(s.transition.to_floor,   s.transition.toFloor,   '')),
    };
  }
  const floorId = String(first(s?.floor, s?.floor_id, s?.level, ''));
  if (!floorId) return null;
  return { type:'floor', floorId, nodeCodes: extractCodes(s) };
}

function normalizeStep(step, index) {
  if (typeof step === 'string') {
    return { index, text:step, floorId:'', isTransition:false };
  }
  const text = String(first(step?.instruction, step?.text, step?.title, step?.description, 'Siga.'));
  const floorId = String(first(step?.floor, step?.floor_id, step?.level, ''));
  const isTransition = !!(step?.transition || step?.transition_type
    || /elev|escad|suba|desc/i.test(text));
  return { index, text, floorId, isTransition };
}

function extractCodes(src) {
  const cands = first(
    src?.node_codes, src?.nodeCodes,
    src?.path_node_codes, src?.pathNodeCodes,
    src?.path, src?.nodes, []
  );
  return asArray(cands).map(item => {
    if (typeof item === 'string' || typeof item === 'number') return String(item);
    return String(first(item?.code, item?.node_code, ''));
  }).filter(Boolean);
}

function buildSegments(codes) {
  const groups = [];
  codes.forEach(code => {
    const n = findNode(code);
    const fid = n?.floorId ?? mapState.selectedFloorId;
    const last = groups[groups.length-1];
    if (!last || last.floorId !== fid)
      groups.push({ type:'floor', floorId:fid, nodeCodes:[] });
    groups[groups.length-1].nodeCodes.push(code);
  });
  return groups;
}

/* ============================================================
   5. SEMANTIC STEP GROUPING
   Collapses raw graph path steps into user-friendly instructions.
   Rules:
   - Corridor/waypoint/junction nodes → absorbed into directional text
   - Floor transitions → explicit "Take [elevator/stairs] to [Floor]"
   - Multiple consecutive same-type service nodes → collapsed
   ============================================================ */

function buildSemanticSteps(route) {
  const { steps, segments, path } = route;
  if (!steps.length && !path.length) return [];

  // If backend steps are strings, try to group them semantically
  const semantic = [];
  let buf = [];

  const flush = () => {
    if (!buf.length) return;
    const texts = buf.map(s => s.text).filter(Boolean);
    if (!texts.length) { buf = []; return; }

    // Check if this is a transition block
    const isFloorChange = buf.some(s => s.isTransition);
    if (isFloorChange) {
      // Find transition info
      const transText = buf.find(s => s.isTransition)?.text ?? 'Mude de piso';
      const cleanTrans = cleanStepText(transText);
      if (cleanTrans) semantic.push({ text:cleanTrans, isTransition:true, floorId:buf[buf.length-1]?.floorId });
    } else {
      // Merge same-floor walking instructions into one
      const merged = mergeWalkingSteps(buf);
      if (merged) semantic.push({ text:merged, isTransition:false, floorId:buf[0]?.floorId });
    }
    buf = [];
  };

  steps.forEach((step, i) => {
    const isInternalNode = isGraphInternalStep(step.text);

    if (step.isTransition) {
      flush();
      const text = cleanStepText(step.text);
      if (text) semantic.push({ text, isTransition:true, floorId:step.floorId });
      return;
    }

    if (isInternalNode) {
      buf.push(step);
      return;
    }

    // Named POI or gate reference → flush buffer, add named step
    flush();
    const text = cleanStepText(step.text);
    if (text) semantic.push({ text, isTransition:false, floorId:step.floorId });
  });

  flush();

  // Add destination arrival if missing
  const destNode = findNode(planState.destinationCode);
  if (destNode && semantic.length) {
    const lastText = semantic[semantic.length-1]?.text ?? '';
    if (!lastText.toLowerCase().includes(norm(destNode.name).slice(0, 6))) {
      semantic.push({
        text: `Chegue a ${destNode.name}.`,
        isTransition: false,
        floorId: destNode.floorId,
      });
    }
  }

  return semantic.length ? semantic : steps.map(s => ({
    text: cleanStepText(s.text) || s.text,
    isTransition: s.isTransition,
    floorId: s.floorId,
  }));
}

const INTERNAL_PATTERNS = [
  /^v[aá] (at[eé] |para )?o (corredor|waypoint|transi[cç][aã]o|n[oó]|n[oó]do)/i,
  /corredor\s+\w+/i,
  /waypoint/i,
  /transi[cç][aã]o\s+\d/i,
  /n[oó]do\s+(interno|t[eé]cnico)/i,
  /^siga\s+(pelo|para o)\s+(corredor|v[aá]o)/i,
];

function isGraphInternalStep(text) {
  return INTERNAL_PATTERNS.some(re => re.test(text));
}

function cleanStepText(raw) {
  if (!raw) return '';
  // Remove internal node codes (snakecase patterns like p2_corredor_a)
  let t = raw.replace(/\b[a-z][a-z0-9]*_[a-z0-9_]+\b/g, '').trim();
  // Remove trailing punctuation artifacts
  t = t.replace(/\s{2,}/g, ' ').replace(/^[,;\s]+|[,;\s]+$/g, '').trim();
  // Capitalize
  return t ? t.charAt(0).toUpperCase() + t.slice(1) : '';
}

function mergeWalkingSteps(steps) {
  if (!steps.length) return '';
  if (steps.length === 1) return cleanStepText(steps[0].text);

  // Try to get a destination hint from last step
  const last = cleanStepText(steps[steps.length-1].text);
  const first_ = cleanStepText(steps[0].text);

  // If first step mentions direction/area, prefer it
  if (/embarque|desembarque|ala|pier|corredor principal/i.test(first_)) return first_;
  if (/embarque|desembarque|ala|pier|corredor principal/i.test(last)) return last;
  if (last && last !== first_) return last;
  return first_;
}

/* ============================================================
   6. SVG MAP — with memoization
   ============================================================ */

const SVG_PAD = 28;

function getFloorBounds(floorId) {
  const ns = appData.nodes.filter(n => n.floorId === floorId);
  if (!ns.length) return { minX:0, maxX:100, minY:0, maxY:100 };
  const xs = ns.map(n=>n.x), ys = ns.map(n=>n.y);
  return { minX:Math.min(...xs), maxX:Math.max(...xs), minY:Math.min(...ys), maxY:Math.max(...ys) };
}

function nodeToSvg(node, bounds, W, H) {
  const rx = bounds.maxX - bounds.minX || 1;
  const ry = bounds.maxY - bounds.minY || 1;
  return {
    x: SVG_PAD + ((node.x - bounds.minX) / rx) * (W - SVG_PAD*2),
    y: SVG_PAD + ((node.y - bounds.minY) / ry) * (H - SVG_PAD*2),
  };
}

function getRouteCodesForFloor(floorId) {
  const seg = navState.route?.segments?.find(s => s.type==='floor' && s.floorId===floorId);
  if (seg?.nodeCodes?.length) return seg.nodeCodes;
  return (navState.route?.path ?? []).filter(c => findNode(c)?.floorId === floorId);
}

/** Build cache key — changes when floor data or route changes */
function svgCacheKey(floorId) {
  const routeHash = navState.route ? `${planState.originCode}|${planState.destinationCode}|${planState.routeMode}` : '';
  const activeStep = navState.navMode ? navState.activeStepIndex : -1;
  return `${floorId}::${routeHash}::${activeStep}`;
}

function buildFloorSvg(floorId) {
  const W = 400, H = 280;
  const floorNodes = appData.nodes.filter(n => n.floorId === floorId);
  if (!floorNodes.length) {
    return `<svg viewBox="0 0 ${W} ${H}" class="sg-map-svg" role="img" aria-label="Sem pontos neste piso"></svg>`;
  }

  const bounds   = getFloorBounds(floorId);
  const toSvg    = n => nodeToSvg(n, bounds, W, H);
  const routeCodes   = getRouteCodesForFloor(floorId);
  const routeSet     = new Set(routeCodes);
  const routePoints  = routeCodes.map(c => {
    const n = findNode(c);
    return (n && n.floorId === floorId) ? toSvg(n) : null;
  }).filter(Boolean);

  const polyline = routePoints.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
  const poiNodes     = floorNodes.filter(n => n.isPoi);
  const internalOnRoute = floorNodes.filter(n => !n.isPoi && routeSet.has(n.code));

  // Origin / destination on this floor
  const originNode = planState.originCode ? findNode(planState.originCode) : null;
  const destNode   = planState.destinationCode ? findNode(planState.destinationCode) : null;
  const showOrigin = originNode?.floorId === floorId;
  const showDest   = destNode?.floorId === floorId;

  // Route mode colors
  const routeColor = planState.routeMode === 'accessible' ? '#0d9488' : '#14b8a6';

  // Active step highlight in nav mode
  let activeCode = null;
  if (navState.navMode && navState.route) {
    const stepIdx = navState.activeStepIndex;
    activeCode = navState.route.path?.[stepIdx] ?? null;
  }

  return `<svg
    viewBox="0 0 ${W} ${H}"
    class="sg-map-svg"
    role="img"
    aria-label="Mapa: ${esc(getFloorLabel(floorId))}"
    style="overflow:visible"
  >
    <defs>
      <filter id="fg${floorId}" x="-30%" y="-30%" width="160%" height="160%">
        <feGaussianBlur stdDeviation="2" result="b"/>
        <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>

    <!-- Map background -->
    <rect width="${W}" height="${H}" fill="#1a2a3d"/>

    <!-- Zone backgrounds from node clusters -->
    ${buildZones(floorId, toSvg, bounds, W, H)}

    <!-- Internal walkable corridor guides -->
    ${internalOnRoute.map(n => {
      const p = toSvg(n);
      return `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="1.5" fill="rgba(255,255,255,0.15)"/>`;
    }).join('')}

    <!-- Route background glow -->
    ${polyline ? `<polyline points="${polyline}" fill="none" stroke="${routeColor}" stroke-width="10" stroke-linecap="round" stroke-linejoin="round" opacity="0.15"/>` : ''}

    <!-- Route track (shadow) -->
    ${polyline ? `<polyline points="${polyline}" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>` : ''}

    <!-- Route animated line -->
    ${polyline ? `<polyline points="${polyline}" fill="none" stroke="${routeColor}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="sg-route-line"/>` : ''}

    <!-- POI nodes -->
    ${poiNodes.map(n => renderPoiNode(n, toSvg, routeSet, activeCode)).join('')}

    <!-- Origin marker -->
    ${showOrigin ? (() => {
      const p = toSvg(originNode);
      return `<g aria-label="Origem: ${esc(originNode.name)}">
        <circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="12" fill="#0a192f" opacity="0.2"/>
        <circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="8" fill="#0a192f" stroke="#fff" stroke-width="2.5"/>
        <circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="3" fill="#fff"/>
        <text x="${p.x.toFixed(1)}" y="${(p.y+22).toFixed(1)}" text-anchor="middle" font-size="8" fill="#fff" font-family="Inter,sans-serif" font-weight="800" paint-order="stroke" stroke="#1a2a3d" stroke-width="3">ORIGEM</text>
      </g>`;
    })() : ''}

    <!-- Destination marker -->
    ${showDest ? (() => {
      const p = toSvg(destNode);
      return `<g aria-label="Destino: ${esc(destNode.name)}">
        <circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="13" fill="${routeColor}" opacity="0.2"/>
        <circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="9" fill="${routeColor}" stroke="#fff" stroke-width="2.5"/>
        <text x="${p.x.toFixed(1)}" y="${p.y.toFixed(1)}" dy="0.37em" text-anchor="middle" font-size="9" fill="#fff" font-family="Inter,sans-serif" font-weight="800">★</text>
        <text x="${p.x.toFixed(1)}" y="${(p.y+23).toFixed(1)}" text-anchor="middle" font-size="8" fill="${routeColor}" font-family="Inter,sans-serif" font-weight="800" paint-order="stroke" stroke="#1a2a3d" stroke-width="3">DESTINO</text>
      </g>`;
    })() : ''}
  </svg>`;
}

function buildZones(floorId, toSvg, bounds, W, H) {
  const ns = appData.nodes.filter(n => n.floorId === floorId);
  if (ns.length < 4) return '';
  const step = (bounds.maxX - bounds.minX) / 3 || 1;
  const zones = [];
  for (let i = 0; i < 3; i++) {
    const zns = ns.filter(n => {
      const nx = n.x - bounds.minX;
      return nx >= i*step && nx < (i+1)*step;
    });
    if (zns.length < 2) continue;
    const pts = zns.map(toSvg);
    const xs = pts.map(p=>p.x), ys = pts.map(p=>p.y);
    zones.push({
      x: Math.min(...xs)-14, y: Math.min(...ys)-14,
      w: Math.max(...xs)-Math.min(...xs)+28,
      h: Math.max(...ys)-Math.min(...ys)+28,
      fill: ['rgba(255,255,255,0.04)','rgba(255,255,255,0.03)','rgba(100,180,255,0.04)'][i],
    });
  }
  return zones.map(z =>
    `<rect x="${z.x.toFixed(1)}" y="${z.y.toFixed(1)}" width="${z.w.toFixed(1)}" height="${z.h.toFixed(1)}" rx="10" fill="${z.fill}"/>`
  ).join('');
}

function renderPoiNode(node, toSvg, routeSet, activeCode) {
  // Skip origin/dest — drawn separately
  if (node.code === planState.originCode || node.code === planState.destinationCode) return '';
  const p       = toSvg(node);
  const onRoute = routeSet.has(node.code);
  const isActive= node.code === activeCode;
  const meta    = getNodeMeta(node.type);
  const r       = isActive ? 7 : onRoute ? 5.5 : 3.5;
  const fill    = onRoute ? meta.color : 'rgba(255,255,255,0.18)';
  const stroke  = onRoute ? '#fff' : 'rgba(255,255,255,0.08)';
  // Show label only for gates and route POIs (reduce clutter)
  const showLabel = node.type === 'gate' || (onRoute && node.isPoi);

  return `<g class="sg-map-node" role="img" aria-label="${esc(node.name)}">
    ${isActive ? `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="${r+6}" fill="${fill}" opacity="0.2"/>` : ''}
    ${onRoute ? `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="${r+3}" fill="${fill}" opacity="0.12"/>` : ''}
    <circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="${r}" fill="${fill}" stroke="${stroke}" stroke-width="1.5"/>
    ${showLabel ? `<text x="${p.x.toFixed(1)}" y="${(p.y-r-3).toFixed(1)}" text-anchor="middle" font-size="7" fill="rgba(255,255,255,${onRoute?'0.9':'0.45'})" font-family="Inter,sans-serif" font-weight="700" paint-order="stroke" stroke="#1a2a3d" stroke-width="2">${esc(node.name.length>16 ? node.name.slice(0,14)+'…' : node.name)}</text>` : ''}
  </g>`;
}

/* Get or build SVG, with cache */
function getFloorSvg(floorId) {
  const key = svgCacheKey(floorId);
  if (mapState.svgCache[floorId]?.key === key) return mapState.svgCache[floorId].svg;
  const svg = buildFloorSvg(floorId);
  mapState.svgCache[floorId] = { key, svg };
  return svg;
}

/** Invalidate cache for floors whose route overlay changed */
function invalidateRouteCache() {
  Object.keys(mapState.svgCache).forEach(fid => {
    delete mapState.svgCache[fid];
  });
}

/* ============================================================
   7. SEARCH HELPERS
   ============================================================ */

function filterNodes(q, exceptCode='') {
  const t = norm(q);
  return appData.nodes
    .filter(n => n.isPoi && n.code !== exceptCode)
    .filter(n => !t || n.searchText.includes(t))
    .slice(0, MAX_RESULTS);
}

function groupByCategory(nodes) {
  const map = new Map();
  nodes.forEach(n => {
    const g = getNodeMeta(n.type).group ?? 'OUTROS';
    if (!map.has(g)) map.set(g, []);
    map.get(g).push(n);
  });
  return map;
}

