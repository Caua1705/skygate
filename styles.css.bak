/* ============================================================
   SKYGATE вЂ” Design System v4
   Three-state UI: planning | summary | navigation
   Mobile-first, semantically clean, premium.
   8px spacing system. Vanilla CSS only. No Tailwind.
   ============================================================ */

/* --- RESET --- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html  { height: 100%; -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
body  {
  min-height: 100dvh; height: 100%;
  font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
  font-size: 15px; line-height: 1.5;
  color: #0f172a; background: #f5f8fc;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow: hidden;
}
button { cursor: pointer; border: none; background: none; font: inherit; color: inherit; }
input, select, textarea { font: inherit; }
img { display: block; max-width: 100%; }
a { text-decoration: none; color: inherit; }

/* --- TOKENS --- */
:root {
  /* Palette */
  --navy-950: #0a192f;
  --navy-900: #0e2038;
  --navy-800: #132d4a;
  --navy-700: #1e3a5f;
  --navy-200: #c8d8e8;
  --navy-50:  #e8f0f8;

  --teal-700: #0e7268;
  --teal-600: #0d9488;
  --teal-500: #14b8a6;
  --teal-400: #2dd4bf;
  --teal-100: #ccfbf1;
  --teal-50:  #f0fdfa;

  --slate-900: #0f172a;
  --slate-700: #334155;
  --slate-600: #475569;
  --slate-500: #64748b;
  --slate-400: #94a3b8;
  --slate-300: #cbd5e1;
  --slate-200: #e2e8f0;
  --slate-100: #f1f5f9;
  --slate-50:  #f8fafc;
  --white:     #ffffff;

  --red-600: #dc2626;
  --red-100: #fee2e2;
  --amber-500: #f59e0b;
  --amber-100: #fef3c7;
  --green-600: #16a34a;
  --green-100: #dcfce7;

  /* Surfaces */
  --surface-page:     #f8fafc;
  --surface-card:     #ffffff;
  --surface-float:    rgba(12, 24, 40, 0.93);
  --surface-overlay:  rgba(10, 25, 47, 0.6);
  --surface-map:      #eef0f4;

  /* Shadows */
  --shadow-xs:  0 1px 2px rgba(0,0,0,.07);
  --shadow-sm:  0 1px 4px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.05);
  --shadow-md:  0 4px 12px rgba(0,0,0,.1),  0 2px 4px rgba(0,0,0,.07);
  --shadow-lg:  0 8px 28px rgba(0,0,0,.14), 0 2px 8px rgba(0,0,0,.08);
  --shadow-xl:  0 16px 48px rgba(0,0,0,.18);
  --shadow-float: 0 4px 20px rgba(0,0,0,.32), 0 1px 4px rgba(0,0,0,.18);

  /* Layout */
  --header-h:     56px;
  --safe-top:     env(safe-area-inset-top, 0px);
  --safe-bottom:  env(safe-area-inset-bottom, 0px);
  --sidebar-w:    380px;
  --card-max-w:   480px;
  --instr-card-h: 148px;

  /* Radius */
  --r-xs: 6px;  --r-sm: 8px;  --r-md: 12px;
  --r-lg: 16px; --r-xl: 20px; --r-2xl: 24px;

  /* Transitions */
  --t-fast:   120ms ease;
  --t-base:   200ms ease;
  --t-slow:   320ms cubic-bezier(0.32,0.72,0,1);
  --t-spring: 380ms cubic-bezier(0.16,1,0.3,1);
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}

/* ============================================================
   APP SHELL
   ============================================================ */

#app {
  position: fixed; inset: 0;
  display: flex; flex-direction: column;
  overflow: hidden;
}

/* Planning mode: allow the inner shell to scroll naturally */
#app:has(.sg-planning) {
  overflow: visible;
  position: relative;
}

/* ============================================================
   UTILITY
   ============================================================ */

.sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0;
  margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
  white-space: nowrap; border: 0;
}
.truncate { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* ============================================================
   SHARED: PLANNING HEADER  (used in planning + summary)
   ============================================================ */

.sg-planning-header {
  display: flex; align-items: center;
  gap: 10px; padding: 0 16px;
  height: var(--header-h); flex-shrink: 0;
  border-bottom: 1px solid var(--slate-200);
  background: var(--white);
}

.sg-planning-logo {
  width: 30px; height: 30px; border-radius: 7px;
  object-fit: cover; flex-shrink: 0;
  border: 1px solid var(--slate-200);
}

.sg-planning-brand { flex: 1; min-width: 0; }

.sg-planning-name {
  font-family: 'Plus Jakarta Sans', sans-serif;
  display: block; font-size: 13px; font-weight: 700;
  color: var(--navy-950); line-height: 1.2; letter-spacing: -0.01em;
}

.sg-planning-loc {
  display: flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 500;
  color: var(--slate-500); margin-top: 1px;
}

.sg-dot {
  width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
  transition: background var(--t-base);
}
.sg-dot--ok      { background: var(--teal-500); }
.sg-dot--loading { background: var(--amber-500); animation: pulse 1.2s ease infinite; }
.sg-dot--error   { background: var(--red-600); }

@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

/* ============================================================
   SHARED: ICON BUTTON
   ============================================================ */

.sg-icon-btn {
  display: grid; place-items: center;
  width: 40px; height: 40px; border-radius: var(--r-sm);
  color: var(--slate-600); font-size: 20px; flex-shrink: 0;
  transition: background var(--t-fast), color var(--t-fast);
}
.sg-icon-btn:hover { background: var(--slate-100); color: var(--navy-950); }
.sg-icon-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* ============================================================
   SHARED: SPINNER
   ============================================================ */

.sg-spinner {
  width: 28px; height: 28px;
  border: 2.5px solid var(--slate-200);
  border-top-color: var(--teal-500); border-radius: 50%;
  animation: spin 0.75s linear infinite;
}
.sg-spinner-sm {
  width: 16px; height: 16px; flex-shrink: 0;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: var(--white); border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ============================================================
/* ============================================================
   1. PLANNING STATE
   ============================================================ */

/* в”Ђв”Ђ Shell в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-planning {
  display: flex; flex-direction: column;
  height: 100%; min-height: 100dvh;
  background: var(--slate-50);
  overflow: hidden;
}

/* в”Ђв”Ђ App Bar в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-appbar {
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0;
  height: 60px;
  padding: 0 8px 0 16px;
  padding-top: var(--safe-top);
  background: var(--white);
  border-bottom: 1px solid var(--slate-100);
}

.sg-appbar__brand {
  display: flex; align-items: center; gap: 10px; min-width: 0;
}

.sg-appbar__logo {
  width: 32px; height: 32px;
  border-radius: 9px; object-fit: cover; flex-shrink: 0;
  box-shadow: 0 1px 3px rgba(0,0,0,.12);
}

.sg-appbar__text { min-width: 0; }

.sg-appbar__name {
  font-family: 'Plus Jakarta Sans', sans-serif;
  display: block; font-size: 15px; font-weight: 800;
  color: var(--navy-950); line-height: 1.15; letter-spacing: -0.025em;
}

.sg-appbar__loc {
  display: flex; align-items: center; gap: 5px;
  font-size: 12px; font-weight: 500;
  color: var(--slate-600); margin-top: 1px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* Legacy header aliases вЂ” used by summary/navigation screens */
.sg-planning-header {
  display: flex; align-items: center;
  gap: 10px; padding: 0 16px;
  height: var(--header-h); flex-shrink: 0;
  border-bottom: 1px solid var(--slate-200);
  background: var(--white);
}
.sg-planning-logo  { width: 30px; height: 30px; border-radius: 7px; object-fit: cover; flex-shrink: 0; border: 1px solid var(--slate-200); }
.sg-planning-brand { flex: 1; min-width: 0; }
.sg-planning-name  { font-family: 'Plus Jakarta Sans', sans-serif; display: block; font-size: 13px; font-weight: 700; color: var(--navy-950); line-height: 1.2; letter-spacing: -0.01em; }
.sg-planning-loc   { display: flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 500; color: var(--slate-500); margin-top: 1px; }

/* в”Ђв”Ђ Main scrollable area в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-planning-main {
  flex: 1; overflow-y: auto; overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  display: flex; flex-direction: column; align-items: center;
  padding-bottom: max(32px, var(--safe-bottom));
}

.sg-planning-scroll {
  width: 100%; max-width: var(--card-max-w);
  padding: 24px 20px 0;
  display: flex; flex-direction: column;
  gap: 0;
}

/* в”Ђв”Ђ Full states (loading / error) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-fullstate {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 16px; padding: 40px 24px;
  text-align: center; color: var(--slate-500);
  font-size: 14px; font-weight: 500;
}
.sg-fullstate--error { color: var(--slate-700); }
.sg-loading-state { display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 40px; color: var(--slate-500); font-size: 14px; }
.sg-error-state   { display: flex; flex-direction: column; align-items: center; gap: 14px; padding: 40px; text-align: center; }
.sg-error-state__msg { font-size: 14px; font-weight: 500; color: var(--slate-700); max-width: 280px; line-height: 1.5; }

/* в”Ђв”Ђ Identity / Heading block в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-identity {
  display: flex; align-items: flex-start; gap: 12px;
  margin-bottom: 20px;
}

.sg-identity__bar {
  flex-shrink: 0; width: 3px; align-self: stretch; min-height: 40px;
  border-radius: 2px;
  background: linear-gradient(to bottom, var(--teal-500), var(--navy-700));
  opacity: 0.7;
}

.sg-identity__text { min-width: 0; }

.sg-planning-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 24px; font-weight: 800;
  color: var(--navy-950); letter-spacing: -0.03em;
  line-height: 1.15; margin-bottom: 5px;
}

.sg-planning-sub {
  font-size: 14px; color: var(--slate-600);
  font-weight: 400; line-height: 1.45;
}

.sg-planning-hero     { text-align: left; }
.sg-planning-headline { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(20px,5vw,26px); font-weight: 800; color: var(--navy-950); letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 6px; }

/* в”Ђв”Ђ Route planner card в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-planner {
  background: var(--white);
  border-radius: var(--r-lg);
  border: 1px solid var(--slate-200);
  overflow: hidden;
  margin-bottom: 24px;
}

.sg-form-card {
  width: 100%; background: var(--white);
  border-radius: var(--r-lg); border: 1px solid var(--slate-200);
  overflow: hidden; display: flex; flex-direction: column;
}

.sg-form-error {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 16px;
  background: var(--red-100); color: var(--red-600);
  font-size: 13px; font-weight: 600;
}
.sg-form-error iconify-icon { font-size: 16px; flex-shrink: 0; }
.sg-form-error button { display: grid; place-items: center; margin-left: auto; font-size: 18px; color: var(--red-600); opacity: .7; min-width: 32px; min-height: 32px; }
.sg-form-error button:hover { opacity: 1; }

/* в”Ђв”Ђ Journey input (origin + destination) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-journey {
  display: flex; align-items: stretch;
  border-bottom: 1px solid var(--slate-100);
  position: relative;
}

.sg-journey__rail {
  display: flex; flex-direction: column; align-items: center;
  padding: 18px 0; width: 44px; flex-shrink: 0;
}

.sg-journey__dot {
  width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
}
.sg-journey__dot--origin { background: var(--navy-700); box-shadow: 0 0 0 3px rgba(30,58,95,.14); }
.sg-journey__dot--dest   { background: var(--teal-600); box-shadow: 0 0 0 3px rgba(13,148,136,.14); }

.sg-journey__line {
  flex: 1; width: 2px; margin: 5px 0;
  background: repeating-linear-gradient(
    to bottom,
    var(--slate-300) 0, var(--slate-300) 4px,
    transparent 4px, transparent 9px
  );
}

.sg-journey__fields {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column;
}

.sg-journey-field {
  display: flex; align-items: center;
  min-height: 60px; width: 100%;
  padding: 0 12px 0 0;
  background: transparent; border: none;
  text-align: left; cursor: pointer;
  transition: background var(--t-fast);
  position: relative;
}
.sg-journey-field:hover { background: var(--slate-50); }
.sg-journey-field:focus-visible { outline: 2px solid var(--teal-500); outline-offset: -2px; border-radius: 4px; }

.sg-journey__sep { height: 1px; background: var(--slate-100); }

.sg-journey-field__inner {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; justify-content: center;
  padding: 10px 8px 10px 0;
}

.sg-journey-field__label {
  font-size: 12px; font-weight: 600; color: var(--slate-500);
  line-height: 1; margin-bottom: 3px;
}

.sg-journey-field__value {
  font-size: 15px; font-weight: 600; color: var(--navy-950);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.3;
}
.sg-journey-field__value.is-ph { color: var(--slate-400); font-weight: 400; }

.sg-journey-field__sub {
  font-size: 12px; color: var(--teal-600); font-weight: 500; margin-top: 2px;
}

.sg-journey-clear {
  flex-shrink: 0; align-self: center;
  width: 32px; height: 32px; border-radius: 50%;
  display: grid; place-items: center;
  font-size: 18px; color: var(--slate-400); cursor: pointer;
  transition: background var(--t-fast), color var(--t-fast);
}
.sg-journey-clear:hover { background: var(--slate-100); color: var(--slate-700); }
.sg-journey-clear:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

.sg-journey__swap {
  flex-shrink: 0; align-self: center;
  width: 36px; height: 36px; border-radius: 50%;
  display: grid; place-items: center;
  margin-right: 8px;
  background: var(--white); border: 1.5px solid var(--slate-200);
  font-size: 18px; color: var(--slate-500);
  box-shadow: var(--shadow-xs);
  transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast), transform 0.2s;
}
.sg-journey__swap:hover:not(:disabled) {
  background: var(--teal-50); border-color: var(--teal-400);
  color: var(--teal-700); transform: scale(1.06);
}
.sg-journey__swap:disabled { opacity: .3; cursor: not-allowed; }
.sg-journey__swap:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* Legacy route-field aliases (used by older render iterations still in cache) */
.sg-route-input { position: relative; border-bottom: 1px solid var(--slate-100); }
.sg-route-input__line { position: absolute; left: 31px; top: 52px; width: 2px; height: 20px; background: repeating-linear-gradient(to bottom, var(--teal-400) 0, var(--teal-400) 3px, transparent 3px, transparent 7px); z-index: 1; opacity: 0.6; }
.sg-route-input__connector { position: absolute; left: 31px; top: 54px; width: 2px; height: 14px; background: repeating-linear-gradient(to bottom, var(--slate-300) 0, var(--slate-300) 3px, transparent 3px, transparent 6px); z-index: 1; }
.sg-route-field { display: flex; align-items: stretch; min-height: 56px; }
.sg-route-field + .sg-route-field { border-top: 1px solid var(--slate-100); }
.sg-route-field__icon { width: 44px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 17px; }
.sg-route-field__icon--origin { color: var(--navy-700); }
.sg-route-field__icon--dest   { color: var(--teal-600); }
.sg-route-field__btn { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; padding: 10px 8px 10px 0; text-align: left; background: transparent; border: none; cursor: pointer; transition: background var(--t-fast); }
.sg-route-field__btn:hover { background: var(--slate-50); }
.sg-route-field__btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: -2px; border-radius: 4px; }
.sg-route-field__label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--slate-400); line-height: 1; margin-bottom: 3px; }
.sg-route-field__value { font-size: 14px; font-weight: 600; color: var(--navy-950); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sg-route-field__value--ph { color: var(--slate-400); font-weight: 400; }
.sg-route-field__sub { font-size: 11px; color: var(--teal-600); font-weight: 500; margin-top: 2px; }
.sg-route-field__clear { flex-shrink: 0; align-self: center; margin-right: 8px; width: 32px; height: 32px; border-radius: 50%; display: grid; place-items: center; font-size: 18px; color: var(--slate-400); transition: background var(--t-fast), color var(--t-fast); }
.sg-route-field__clear:hover { background: var(--slate-100); color: var(--navy-950); }
.sg-route-field__clear:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }
.sg-swap-btn { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); width: 32px; height: 32px; border-radius: 50%; display: grid; place-items: center; background: var(--white); border: 1.5px solid var(--slate-200); font-size: 16px; color: var(--slate-500); z-index: 2; box-shadow: var(--shadow-xs); transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast); }
.sg-swap-btn:hover:not(:disabled) { background: var(--teal-50); border-color: var(--teal-400); color: var(--teal-600); }
.sg-swap-btn:disabled { opacity: .3; cursor: not-allowed; }
.sg-swap-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Accessible route row в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-access-row {
  display: flex; align-items: center;
  min-height: 52px;
  padding: 10px 16px 10px 44px;
  gap: 12px;
  border-bottom: 1px solid var(--slate-100);
  transition: background var(--t-fast);
}
.sg-access-row:hover { background: var(--slate-50); }

.sg-access-row__label {
  display: flex; align-items: center; gap: 10px;
  flex: 1; cursor: pointer; min-width: 0;
}

.sg-access-row__icon { font-size: 18px; color: var(--slate-400); flex-shrink: 0; transition: color var(--t-fast); }
.sg-access-row__icon.is-on { color: var(--teal-600); }

.sg-access-row__text { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.sg-access-row__title { font-size: 14px; font-weight: 600; color: var(--navy-950); line-height: 1.2; }
.sg-access-row__desc  { font-size: 12px; color: var(--slate-500); font-weight: 400; line-height: 1.3; }

/* Toggle switch */
.sg-toggle {
  position: relative; flex-shrink: 0;
  width: 44px; height: 26px; border-radius: 13px;
  background: var(--slate-200); border: none; cursor: pointer;
  transition: background var(--t-base);
}
.sg-toggle.is-on { background: var(--teal-600); }
.sg-toggle:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 3px; }
.sg-toggle__thumb {
  position: absolute; top: 3px; left: 3px;
  width: 20px; height: 20px; border-radius: 50%;
  background: var(--white); box-shadow: 0 1px 4px rgba(0,0,0,.22);
  transition: transform var(--t-base);
}
.sg-toggle.is-on .sg-toggle__thumb { transform: translateX(18px); }

/* Accessible-row legacy aliases */
.sg-accessible-row { display: flex; align-items: center; padding: 12px 14px 12px 16px; gap: 12px; border-bottom: 1px solid var(--slate-100); transition: background var(--t-fast); cursor: pointer; }
.sg-accessible-row:hover { background: var(--slate-50); }
.sg-accessible-label { display: flex; align-items: center; gap: 12px; flex: 1; cursor: pointer; }
.sg-accessible-icon { font-size: 20px; color: var(--slate-400); flex-shrink: 0; transition: color var(--t-fast); }
.sg-accessible-icon.is-active { color: var(--teal-600); }
.sg-accessible-text { display: flex; flex-direction: column; gap: 1px; }
.sg-accessible-title { font-size: 14px; font-weight: 600; color: var(--navy-950); }
.sg-accessible-desc  { font-size: 11px; color: var(--slate-500); font-weight: 400; }

/* в”Ђв”Ђ CTA в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-planner__action { padding: 14px 16px 16px; display: flex; flex-direction: column; gap: 8px; }
.sg-form-actions    { padding: 14px 16px; display: flex; flex-direction: column; gap: 8px; }

.sg-calc-btn {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  min-height: 52px; width: 100%;
  background: var(--navy-950); color: var(--white);
  border-radius: var(--r-md);
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 15px; font-weight: 700; letter-spacing: -0.01em;
  transition: background var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast);
}
.sg-calc-btn:hover:not(:disabled) {
  background: var(--navy-800); transform: translateY(-1px);
  box-shadow: 0 4px 14px rgba(15,23,42,.28);
}
.sg-calc-btn:disabled {
  background: var(--slate-100); color: var(--slate-400);
  cursor: not-allowed; box-shadow: none;
  min-height: 44px; font-size: 14px;
}
.sg-calc-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }
.sg-calc-btn iconify-icon { font-size: 18px; }

.sg-form-hint { text-align: center; font-size: 12px; color: var(--slate-400); line-height: 1.4; }
.sg-form-hint.is-warn { color: var(--red-600); font-weight: 600; }
.sg-form-hint--warn   { color: var(--red-600); font-weight: 600; }

/* в”Ђв”Ђ Quick destinations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-quick { margin-bottom: 32px; }

.sg-quick__title {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--slate-400);
  margin-bottom: 10px; padding: 0 2px;
}

.sg-quick__grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}

.sg-quick__item {
  display: flex; align-items: center; gap: 12px;
  padding: 14px; text-align: left;
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--r-md);
  cursor: pointer;
  transition: background var(--t-fast), border-color var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast);
}
.sg-quick__item:hover {
  background: var(--teal-50); border-color: var(--teal-300);
  transform: translateY(-1px); box-shadow: var(--shadow-xs);
}
.sg-quick__item:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }
.sg-quick__item:active { transform: none; }

.sg-quick__icon { font-size: 20px; color: var(--navy-700); flex-shrink: 0; line-height: 1; }
.sg-quick__item:hover .sg-quick__icon { color: var(--teal-700); }

.sg-quick__text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.sg-quick__name { font-size: 14px; font-weight: 600; color: var(--navy-950); line-height: 1.2; }
.sg-quick__sub  { font-size: 12px; color: var(--slate-500); font-weight: 400; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* Legacy quick-item (bindEvents compat) */
.sg-quick-item { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 12px 8px; background: var(--white); border: 1px solid var(--slate-200); border-radius: var(--r-md); cursor: pointer; transition: background var(--t-fast); }
.sg-quick-item:hover { background: var(--teal-50); border-color: var(--teal-400); }
.sg-quick-item:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Shared buttons в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-btn-primary {
  display: flex; align-items: center; justify-content: center; gap: 7px;
  min-height: 48px; width: 100%;
  background: var(--teal-600); color: var(--white);
  border-radius: var(--r-md); font-size: 14px; font-weight: 700;
  box-shadow: 0 2px 8px rgba(13,148,136,.28);
  transition: background var(--t-fast), transform var(--t-fast);
}
.sg-btn-primary--large { min-height: 52px; font-size: 15px; }
.sg-btn-primary:hover { background: var(--teal-700); transform: translateY(-1px); }
.sg-btn-primary:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }
.sg-btn-primary iconify-icon { font-size: 16px; }

.sg-btn-secondary {
  display: flex; align-items: center; justify-content: center; gap: 7px;
  min-height: 44px; width: 100%;
  background: var(--white); color: var(--navy-950);
  border: 1.5px solid var(--slate-300); border-radius: var(--r-md);
  font-size: 14px; font-weight: 600;
  transition: background var(--t-fast), border-color var(--t-fast);
}
.sg-btn-secondary:hover { background: var(--slate-50); border-color: var(--slate-400); }
.sg-btn-secondary:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }
.sg-btn-secondary iconify-icon { font-size: 15px; }

/* в”Ђв”Ђ Mode seg (legacy) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-mode-seg { display: flex; gap: 8px; padding: 12px 16px; }
.sg-mode-btn { flex: 1; min-height: 40px; display: flex; align-items: center; justify-content: center; gap: 6px; border-radius: var(--r-sm); font-size: 13px; font-weight: 600; background: var(--slate-100); color: var(--slate-600); border: 1.5px solid transparent; transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast); }
.sg-mode-btn.is-active { background: var(--navy-950); color: var(--white); border-color: var(--navy-950); }
.sg-mode-btn:not(.is-active):hover { background: var(--slate-200); color: var(--navy-900); }
.sg-mode-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }
.sg-mode-btn iconify-icon { font-size: 15px; }

/* в”Ђв”Ђ Responsive в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
@media (min-width: 480px) {
  .sg-planning-scroll { padding: 28px 24px 0; }
  .sg-planning-title  { font-size: 26px; }
}
@media (min-width: 640px) {
  .sg-planning-scroll { padding: 32px 24px 0; }
}


   2. SUMMARY STATE
   ============================================================ */

.sg-summary-screen {
  display: flex; flex-direction: column;
  height: 100%; min-height: 100dvh;
  background: var(--surface-page);
}

.sg-summary-body {
  flex: 1; overflow-y: auto;
  padding: 20px;
  padding-bottom: max(20px, var(--safe-bottom));
  display: flex; flex-direction: column; gap: 16px;
  max-width: var(--card-max-w); margin: 0 auto; width: 100%;
}

/* Destination hero */
.sg-summary-hero {
  background: var(--white);
  border-radius: var(--r-xl); border: 1px solid var(--slate-200);
  padding: 18px 16px; display: flex; align-items: flex-start; gap: 14px;
  box-shadow: var(--shadow-sm);
}

.sg-summary-dest-icon {
  width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
  display: grid; place-items: center; font-size: 22px;
}

.sg-summary-dest-floor {
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--slate-400); margin-bottom: 2px;
}

.sg-summary-dest-name {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 20px; font-weight: 800; color: var(--navy-950);
  letter-spacing: -0.02em; line-height: 1.2;
}

.sg-mode-pill {
  margin-left: auto; flex-shrink: 0;
  display: inline-flex; align-items: center; gap: 4px;
  padding: 5px 10px; border-radius: 20px;
  font-size: 11px; font-weight: 700; white-space: nowrap;
  align-self: flex-start;
}
.sg-mode-pill--fastest    { background: var(--navy-50);  color: var(--navy-700); border: 1px solid var(--navy-200); }
.sg-mode-pill--accessible { background: var(--teal-50);  color: var(--teal-700); border: 1px solid var(--teal-100); }
.sg-mode-pill iconify-icon { font-size: 12px; }

/* Stats row */
.sg-summary-stats {
  background: var(--white); border-radius: var(--r-xl);
  border: 1px solid var(--slate-200); padding: 16px;
  display: flex; align-items: center; gap: 0; box-shadow: var(--shadow-sm);
}

.sg-stat {
  flex: 1; text-align: center; display: flex; flex-direction: column; gap: 2px;
}

.sg-stat__value {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 24px; font-weight: 800; color: var(--navy-950);
  letter-spacing: -0.04em; display: flex; align-items: baseline; justify-content: center; gap: 2px;
}

.sg-stat__unit { font-size: 12px; font-weight: 600; color: var(--slate-400); letter-spacing: 0; }
.sg-stat__label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--slate-400); }

.sg-stat-div { width: 1px; height: 32px; background: var(--slate-200); flex-shrink: 0; }

/* First step preview */
.sg-summary-preview {
  background: var(--navy-950); border-radius: var(--r-lg);
  padding: 14px 16px; display: flex; align-items: center; gap: 12px;
}

.sg-summary-preview__icon {
  width: 32px; height: 32px; flex-shrink: 0;
  border-radius: 8px; background: rgba(255,255,255,.12);
  display: grid; place-items: center; font-size: 15px; color: var(--teal-400);
}

.sg-summary-preview__label {
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.07em; color: rgba(255,255,255,.4); margin-bottom: 3px;
}

.sg-summary-preview__text { font-size: 13px; font-weight: 600; color: var(--white); line-height: 1.4; }

/* Actions */
.sg-summary-actions {
  display: flex; flex-direction: column; gap: 8px;
}

/* Steps accordion */
.sg-summary-steps {
  background: var(--white); border-radius: var(--r-xl);
  border: 1px solid var(--slate-200); overflow: hidden;
  box-shadow: var(--shadow-xs);
}

.sg-summary-steps__toggle {
  list-style: none; display: flex; align-items: center; gap: 8px;
  padding: 14px 16px; font-size: 13px; font-weight: 600; color: var(--slate-600);
  cursor: pointer; user-select: none;
  transition: background var(--t-fast);
}
.sg-summary-steps__toggle:hover { background: var(--slate-50); }
.sg-summary-steps__toggle::marker { display: none; }
.sg-summary-steps__toggle::-webkit-details-marker { display: none; }
.sg-summary-steps__toggle iconify-icon:first-child { font-size: 15px; color: var(--slate-400); }
.sg-summary-steps__chevron { margin-left: auto; font-size: 14px; color: var(--slate-400); transition: transform var(--t-base); }
details[open] .sg-summary-steps__chevron { transform: rotate(180deg); }

.sg-summary-steps__list {
  list-style: none; padding: 0 0 12px;
  border-top: 1px solid var(--slate-100);
}

.sg-summary-step {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 16px; position: relative;
}
.sg-summary-step + .sg-summary-step::before {
  content: ''; position: absolute; left: 28px; top: 0;
  width: 1px; height: 10px; background: var(--slate-200);
}

.sg-summary-step__num {
  flex-shrink: 0; width: 22px; height: 22px; border-radius: 50%;
  background: var(--slate-100); color: var(--slate-600);
  font-size: 10px; font-weight: 700;
  display: grid; place-items: center;
}
.sg-summary-step--transition .sg-summary-step__num { background: var(--amber-100); color: var(--amber-500); }

.sg-summary-step__text { font-size: 13px; color: var(--slate-700); flex: 1; line-height: 1.4; }

.sg-summary-step__floor {
  flex-shrink: 0; font-size: 10px; font-weight: 600;
  color: var(--teal-600); white-space: nowrap;
}

/* Edit route */
.sg-edit-btn {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  min-height: 40px; font-size: 13px; font-weight: 600; color: var(--slate-500);
  transition: color var(--t-fast);
  padding-bottom: 4px;
}
.sg-edit-btn:hover { color: var(--navy-950); }
.sg-edit-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* ============================================================
   3. NAVIGATION STATE
   ============================================================ */

.sg-nav-screen {
  position: fixed; inset: 0;
  display: flex; flex-direction: column;
  background: var(--surface-map);
}

/* Map area */
.sg-map-area {
  position: absolute; inset: 0;
  overflow: hidden;
  background: var(--surface-map);
  touch-action: none; cursor: grab;
}
.sg-map-area.is-grabbing { cursor: grabbing; }

.sg-map-wrapper {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
}

.sg-map-inner {
  position: relative;
  width: 900px; height: 600px;
  transform-origin: center center;
  will-change: transform;
}

.sg-map-layer {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
}

.sg-map-layer--route { pointer-events: none; }

.sg-map-svg {
  display: block; width: 100%; height: 100%;
  user-select: none; -webkit-user-select: none;
}
.sg-map-base { background: var(--surface-map); border-radius: 12px; overflow: hidden; }

/* Route animation */
.sg-route-active {
  stroke-dasharray: none;
}

@media not (prefers-reduced-motion: reduce) {
  .sg-route-draw {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: routeReveal 420ms ease forwards;
  }
  @keyframes routeReveal {
    from { stroke-dashoffset: 1000; }
    to   { stroke-dashoffset: 0; }
  }
}

/* Compact navigation header */
.sg-nav-header {
  position: absolute;
  top: 0; left: 0; right: 0; z-index: 30;
  height: calc(var(--header-h) + var(--safe-top));
  padding-top: var(--safe-top);
  display: flex; align-items: center; gap: 10px;
  padding-left: 8px; padding-right: 12px;
  background: var(--navy-950);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}

.sg-nav-header__back {
  display: grid; place-items: center;
  width: 40px; height: 40px; border-radius: var(--r-sm); flex-shrink: 0;
  color: rgba(255,255,255,.75); font-size: 20px;
  transition: background var(--t-fast), color var(--t-fast);
}
.sg-nav-header__back:hover { background: rgba(255,255,255,.1); color: var(--white); }
.sg-nav-header__back:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

.sg-nav-header__dest { flex: 1; min-width: 0; }
.sg-nav-header__dest-name {
  display: block; font-size: 13px; font-weight: 600; color: var(--white);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.sg-nav-header__dest-time {
  display: block; font-size: 11px; font-weight: 500; color: rgba(255,255,255,.5);
}

.sg-nav-header__badge {
  display: grid; place-items: center;
  width: 34px; height: 34px; border-radius: 50%;
  background: rgba(13,148,136,.25); color: var(--teal-400); font-size: 17px;
  flex-shrink: 0;
}

/* Floor control (compact floating) */
.sg-floor-ctrl {
  position: absolute;
  top: calc(var(--header-h) + var(--safe-top) + 10px);
  left: 12px; z-index: 40;
}

.sg-floor-trigger {
  display: flex; align-items: center; gap: 7px;
  height: 36px; padding: 0 12px 0 10px;
  background: var(--surface-float);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,.12); border-radius: 18px;
  color: var(--white); font-size: 13px; font-weight: 600;
  box-shadow: var(--shadow-float); white-space: nowrap;
  transition: background var(--t-fast);
}
.sg-floor-trigger:hover { background: rgba(12,24,40,.98); }
.sg-floor-trigger:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }
.sg-floor-trigger iconify-icon { font-size: 15px; color: var(--teal-400); flex-shrink: 0; }
.sg-floor-trigger__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--teal-400); }
.sg-floor-trigger__chevron {
  font-size: 13px; color: rgba(255,255,255,.5); margin-left: 2px;
  transition: transform var(--t-base);
}
.sg-floor-ctrl.is-open .sg-floor-trigger__chevron { transform: rotate(180deg); }

.sg-floor-menu {
  position: absolute; top: calc(100% + 6px); left: 0;
  background: var(--surface-float);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,.12); border-radius: var(--r-lg);
  overflow: hidden; min-width: 160px;
  box-shadow: var(--shadow-float);
  animation: popIn var(--t-base) ease; transform-origin: top left;
}
@keyframes popIn {
  from { opacity:0; transform: scale(.92) translateY(-4px); }
  to   { opacity:1; transform: scale(1) translateY(0); }
}

.sg-floor-item {
  display: flex; align-items: center; gap: 10px;
  width: 100%; min-height: 44px; padding: 0 14px;
  font-size: 13px; font-weight: 600; color: rgba(255,255,255,.75);
  border-bottom: 1px solid rgba(255,255,255,.07);
  transition: background var(--t-fast); cursor: pointer;
}
.sg-floor-item:last-child { border-bottom: none; }
.sg-floor-item:hover { background: rgba(255,255,255,.09); color: var(--white); }
.sg-floor-item.is-active { background: rgba(13,148,136,.2); color: var(--teal-400); }
.sg-floor-item:focus-visible { outline: 2px solid var(--teal-500); outline-offset: -2px; }
.sg-floor-item iconify-icon { font-size: 16px; flex-shrink: 0; }
.sg-floor-item__badge { margin-left: auto; width: 7px; height: 7px; border-radius: 50%; background: var(--teal-400); }

/* Floating action buttons */
.sg-map-fabs {
  position: absolute;
  top: calc(var(--header-h) + var(--safe-top) + 10px);
  right: 12px; z-index: 40;
  display: flex; flex-direction: column; gap: 6px;
}

.sg-map-fab {
  width: 38px; height: 38px; border-radius: 10px;
  display: grid; place-items: center; font-size: 19px;
  background: var(--surface-float);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,.12);
  color: rgba(255,255,255,.8);
  box-shadow: var(--shadow-float);
  transition: background var(--t-fast), color var(--t-fast);
}
.sg-map-fab:hover { background: rgba(12,24,40,.98); color: var(--white); }
.sg-map-fab:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* Return to route button */
.sg-return-btn {
  position: absolute;
  bottom: calc(var(--instr-card-h) + 12px);
  left: 50%; transform: translateX(-50%);
  z-index: 40;
  display: flex; align-items: center; gap: 6px;
  height: 36px; padding: 0 16px;
  background: var(--teal-600); color: var(--white);
  border-radius: 18px; font-size: 12px; font-weight: 700;
  box-shadow: var(--shadow-float);
  transition: opacity var(--t-base), background var(--t-fast);
  white-space: nowrap;
}
.sg-return-btn:hover { background: var(--teal-700); }
.sg-return-btn:focus-visible { outline: 2px solid var(--white); outline-offset: 2px; }
.sg-return-btn.is-hidden { opacity: 0; pointer-events: none; }

/* Floor change announcement */
.sg-floor-announce {
  position: absolute;
  top: calc(var(--header-h) + var(--safe-top) + 52px);
  left: 50%; transform: translateX(-50%) translateY(-6px);
  z-index: 45;
  background: var(--navy-950); color: var(--white);
  padding: 6px 16px; border-radius: 20px;
  font-size: 12px; font-weight: 700; white-space: nowrap;
  opacity: 0; pointer-events: none;
  transition: opacity 200ms, transform 200ms;
  box-shadow: var(--shadow-float);
}
.sg-floor-announce.is-visible {
  opacity: 1; transform: translateX(-50%) translateY(0);
}
.sg-floor-announce--manual { background: var(--teal-600); }

/* ============================================================
   INSTRUCTION CARD
   ============================================================ */

.sg-instruction-card {
  position: absolute;
  bottom: 0; left: 0; right: 0; z-index: 35;
  background: var(--white);
  border-radius: 20px 20px 0 0;
  box-shadow: 0 -4px 24px rgba(0,0,0,.14);
  padding-bottom: max(16px, var(--safe-bottom));
  min-height: var(--instr-card-h);
  display: flex; flex-direction: column;
}

.sg-instr-progress {
  height: 3px; background: var(--slate-100); border-radius: 0;
  flex-shrink: 0; overflow: hidden;
}
.sg-instr-progress__bar {
  height: 100%; background: var(--teal-500); border-radius: 0;
  transition: width var(--t-base);
}

.sg-instr-meta {
  display: flex; align-items: center; gap: 5px;
  padding: 8px 16px 0;
  font-size: 11px; font-weight: 600; color: var(--slate-400);
}

.sg-instr-text {
  flex: 1; padding: 6px 16px;
  font-size: 15px; font-weight: 600; color: var(--navy-950);
  line-height: 1.45;
}

.sg-instr-floor-hint {
  display: flex; align-items: center; gap: 4px;
  padding: 0 16px 4px;
  font-size: 11px; font-weight: 600; color: var(--teal-600);
}

.sg-instr-controls {
  display: flex; align-items: center;
  padding: 6px 12px 4px; gap: 8px;
}

.sg-instr-prev, .sg-instr-next {
  display: flex; align-items: center; gap: 5px;
  min-height: 44px; padding: 0 14px;
  border-radius: var(--r-sm); font-size: 13px; font-weight: 600;
  background: var(--slate-100); color: var(--slate-700);
  transition: background var(--t-fast), color var(--t-fast);
}
.sg-instr-prev:hover:not(:disabled), .sg-instr-next:hover:not(:disabled) {
  background: var(--slate-200); color: var(--navy-950);
}
.sg-instr-prev:disabled, .sg-instr-next:disabled { opacity: .3; cursor: not-allowed; }
.sg-instr-prev:focus-visible, .sg-instr-next:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }
.sg-instr-prev iconify-icon, .sg-instr-next iconify-icon { font-size: 15px; }

.sg-instr-next {
  flex: 1; justify-content: center;
  background: var(--navy-950); color: var(--white);
}
.sg-instr-next:hover:not(:disabled) { background: var(--navy-800); }

.sg-instr-dots {
  flex: 0; display: flex; align-items: center; gap: 4px; flex-shrink: 0;
}

.sg-instr-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--slate-300); transition: background var(--t-base), width var(--t-base);
}
.sg-instr-dot.is-active { width: 16px; border-radius: 3px; background: var(--teal-500); }
.sg-instr-dot.is-done { background: var(--teal-300); }

.sg-instr-counter {
  font-size: 11px; font-weight: 600; color: var(--slate-400);
}

/* ============================================================
   ROUTE OVERVIEW OVERLAY
   ============================================================ */

.sg-overview-overlay {
  position: fixed; inset: 0; z-index: 70;
  display: flex; flex-direction: column; justify-content: flex-end;
}

.sg-overview-backdrop {
  position: absolute; inset: 0;
  background: var(--surface-overlay);
  backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
  border: none; width: 100%; cursor: pointer;
}

.sg-overview-sheet {
  position: relative; z-index: 1;
  background: var(--white); border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  max-height: 78dvh; display: flex; flex-direction: column;
  box-shadow: 0 -8px 40px rgba(0,0,0,.2);
  animation: sheetUp var(--t-base) ease; padding-bottom: var(--safe-bottom);
}

@keyframes sheetUp {
  from { transform: translateY(24px); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}

.sg-overview-handle {
  width: 32px; height: 4px; border-radius: 2px;
  background: var(--slate-200); margin: 10px auto 0;
}

.sg-overview-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 16px 10px; flex-shrink: 0;
  border-bottom: 1px solid var(--slate-100);
}

.sg-overview-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 16px; font-weight: 800; color: var(--navy-950);
}

.sg-overview-dest {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 16px 10px; flex-shrink: 0;
  font-size: 12px; font-weight: 600; color: var(--slate-500);
  border-bottom: 1px solid var(--slate-100);
}
.sg-overview-dest iconify-icon { font-size: 14px; color: var(--teal-600); }

.sg-overview-list {
  flex: 1; overflow-y: auto; list-style: none; padding: 8px 0;
  overscroll-behavior: contain; -webkit-overflow-scrolling: touch;
}
.sg-overview-list::-webkit-scrollbar { width: 4px; }
.sg-overview-list::-webkit-scrollbar-thumb { background: var(--slate-200); border-radius: 2px; }

.sg-overview-item {
  position: relative;
}

.sg-overview-item__btn {
  display: flex; align-items: center; gap: 12px;
  width: 100%; min-height: 56px; padding: 10px 16px;
  text-align: left; transition: background var(--t-fast); cursor: pointer;
}
.sg-overview-item__btn:hover { background: var(--slate-50); }
.sg-overview-item__btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: -2px; }

.sg-overview-item__icon {
  flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%;
  background: var(--slate-100); display: grid; place-items: center;
  font-size: 15px; color: var(--slate-500);
}
.sg-overview-item.is-active .sg-overview-item__icon { background: var(--navy-950); color: var(--white); }
.sg-overview-item.is-done   .sg-overview-item__icon { background: var(--teal-100); color: var(--teal-700); }
.sg-overview-item.is-transition .sg-overview-item__icon { background: var(--amber-100); color: var(--amber-500); }

.sg-overview-item__text {
  font-size: 13px; font-weight: 600; color: var(--navy-950); line-height: 1.4;
}
.sg-overview-item.is-done .sg-overview-item__text { color: var(--slate-400); }

.sg-overview-item__floor {
  font-size: 10px; font-weight: 600; color: var(--teal-600); margin-top: 2px;
}

.sg-overview-connector {
  position: absolute; left: 32px; top: 56px;
  width: 1px; height: 16px; background: var(--slate-200); bottom: 0;
}

/* On desktop, sheets become centered modals */
@media (min-width: 640px) {
  .sg-overview-overlay { justify-content: center; align-items: center; }
  .sg-overview-sheet {
    border-radius: var(--r-xl);
    width: min(560px, calc(100vw - 32px));
    max-height: 80dvh;
  }
  .sg-overview-handle { display: none; }
}

/* ============================================================
   SEARCH OVERLAY
   ============================================================ */

.sg-search-overlay {
  position: fixed; inset: 0; z-index: 80;
  display: flex; flex-direction: column; justify-content: flex-end;
}

.sg-search-backdrop {
  position: absolute; inset: 0;
  background: rgba(10,25,47,.5);
  backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
  border: none; width: 100%; cursor: pointer;
}

.sg-search-sheet {
  position: relative; z-index: 1;
  background: var(--white); border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  max-height: 88dvh; display: flex; flex-direction: column;
  box-shadow: 0 -8px 40px rgba(0,0,0,.2);
  animation: sheetUp var(--t-base) ease;
}

.sg-search-handle {
  width: 32px; height: 4px; border-radius: 2px;
  background: var(--slate-200); margin: 10px auto 0;
}

.sg-search-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px 10px; flex-shrink: 0;
}
.sg-search-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 15px; font-weight: 800; color: var(--navy-950);
}

.sg-search-input-wrap {
  display: flex; align-items: center; gap: 8px;
  min-height: 46px; margin: 0 16px;
  background: var(--slate-50); border: 1.5px solid var(--slate-200);
  border-radius: var(--r-md); padding: 0 12px; flex-shrink: 0;
  transition: border-color var(--t-fast), box-shadow var(--t-fast);
}
.sg-search-input-wrap:focus-within {
  border-color: var(--teal-500);
  box-shadow: 0 0 0 3px rgba(20,184,166,.12);
  background: var(--white);
}
.sg-search-input-wrap iconify-icon { font-size: 16px; color: var(--slate-400); flex-shrink: 0; }

.sg-search-input {
  flex: 1; background: transparent; border: none; outline: none;
  font-size: 15px; font-weight: 500; color: var(--navy-950);
}
.sg-search-input::placeholder { color: var(--slate-400); }

.sg-quick-chips {
  display: flex; gap: 6px; padding: 10px 16px 6px;
  overflow-x: auto; scrollbar-width: none; flex-shrink: 0;
}
.sg-quick-chips::-webkit-scrollbar { display: none; }

.sg-chip {
  flex-shrink: 0; height: 32px; padding: 0 12px;
  border-radius: 16px; border: 1px solid var(--slate-200);
  background: var(--white); font-size: 12px; font-weight: 600;
  color: var(--slate-600); white-space: nowrap;
  transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast);
}
.sg-chip:hover { background: var(--teal-50); border-color: var(--teal-400); color: var(--teal-700); }
.sg-chip:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

.sg-search-results {
  flex: 1; overflow-y: auto; overscroll-behavior: contain;
  -webkit-overflow-scrolling: touch;
}
.sg-search-results::-webkit-scrollbar { width: 4px; }
.sg-search-results::-webkit-scrollbar-thumb { background: var(--slate-200); border-radius: 2px; }

.sg-search-group { padding: 12px 16px 4px; }
.sg-search-group__label {
  font-size: 10px; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--slate-400); margin-bottom: 4px;
}

.sg-search-item {
  display: flex; align-items: center; gap: 12px;
  width: 100%; min-height: 58px; padding: 8px 8px;
  border-radius: var(--r-sm); text-align: left; cursor: pointer;
  transition: background var(--t-fast);
}
.sg-search-item:hover { background: var(--slate-50); }
.sg-search-item:focus-visible { outline: 2px solid var(--teal-500); outline-offset: -2px; }

.sg-search-item__icon {
  width: 38px; height: 38px; border-radius: 10px;
  background: var(--slate-100); display: grid; place-items: center;
  font-size: 18px; flex-shrink: 0;
}

.sg-search-item__body { flex: 1; min-width: 0; }
.sg-search-item__name { font-size: 13px; font-weight: 600; color: var(--navy-950); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sg-search-item__meta { font-size: 11px; color: var(--slate-400); font-weight: 500; margin-top: 1px; }
.sg-search-item__arrow { font-size: 14px; color: var(--slate-300); flex-shrink: 0; }

.sg-search-empty {
  display: flex; flex-direction: column; align-items: center;
  gap: 8px; padding: 40px 24px; text-align: center;
}
.sg-search-empty iconify-icon { font-size: 32px; color: var(--slate-300); }
.sg-search-empty p:first-of-type { font-size: 14px; font-weight: 700; color: var(--navy-950); }
.sg-search-empty__sub { font-size: 12px; color: var(--slate-400); }

/* ============================================================
   DESKTOP LAYOUT (в‰Ґ 1024px)
   ============================================================ */

@media (min-width: 1024px) {
  /* Planning + summary: centered cards */
  .sg-planning, .sg-summary-screen {
    max-width: 100%; align-items: stretch;
  }
  .sg-planning-body, .sg-summary-body {
    justify-content: flex-start; align-items: center;
    padding-top: 40px;
  }
  .sg-form-card { min-width: 440px; }

  /* Navigation: sidebar layout */
  .sg-nav-screen { flex-direction: row; }
  .sg-map-area { position: static; flex: 1; }

  /* On desktop, instruction card becomes a side panel at bottom of sidebar */
  .sg-instruction-card {
    position: static; border-radius: 0;
    box-shadow: 0 -1px 0 var(--slate-200);
  }

  /* Sidebar panel */
  .sg-nav-sidebar {
    width: var(--sidebar-w); flex-shrink: 0;
    background: var(--white); display: flex; flex-direction: column;
    border-right: 1px solid var(--slate-200); z-index: 30;
  }
  .sg-nav-header {
    position: static; height: var(--header-h); padding-top: 0;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }

  .sg-floor-ctrl { top: calc(var(--header-h) + 10px); }
  .sg-map-fabs { top: calc(var(--header-h) + 10px); }

  /* Overlay overlays: centered */
  .sg-search-overlay { justify-content: center; align-items: center; }
  .sg-search-sheet {
    border-radius: var(--r-xl);
    width: min(600px, calc(100vw - 32px)); max-height: 80dvh;
  }
  .sg-search-handle { display: none; }
}

/* ============================================================
   ACCESSIBILITY CONTRAST HELPERS
   ============================================================ */

@media (prefers-contrast: high) {
  .sg-form-card { border-color: var(--navy-700); }
  .sg-route-field__value--ph { color: var(--slate-700); }
  .sg-instr-text { color: var(--navy-950); }
  .sg-floor-trigger { border-color: rgba(255,255,255,.4); }
}

/* ============================================================
   PLANNING SCREEN REFINEMENT
   Scoped to the initial route-planning state: summary and navigation
   screens keep their existing visual treatment.
   ============================================================ */
.sg-planning {
  background: #f6f8fb;
}

.sg-planning .sg-appbar {
  height: calc(60px + var(--safe-top));
  padding: var(--safe-top) 16px 0;
  background: #f6f8fb;
  border-bottom: 0;
  box-shadow: none;
}
.sg-planning .sg-appbar__brand { gap: 9px; }
.sg-planning .sg-appbar__logo { width: 30px; height: 30px; border-radius: 8px; border-color: rgba(30,58,95,.12); }
.sg-planning .sg-appbar__name { font-size: 14px; }
.sg-planning .sg-appbar__loc { color: var(--slate-600); font-size: 12px; }
.sg-planning .sg-icon-btn { width: 44px; height: 44px; color: var(--navy-700); }

.sg-planning .sg-planning-main { align-items: stretch; }
.sg-planning .sg-planning-scroll {
  max-width: 480px;
  margin: 0 auto;
  padding: 24px 16px max(20px, var(--safe-bottom));
  gap: 24px;
}
.sg-planning .sg-planning-heading {
  position: relative;
  padding: 0 2px;
}
.sg-planning .sg-planning-heading::after {
  content: '';
  display: block;
  width: 46px;
  height: 2px;
  margin-top: 14px;
  background: var(--teal-500);
  border-radius: 99px;
  opacity: .75;
}
.sg-planning .sg-planning-title { font-size: clamp(24px, 6vw, 26px); line-height: 1.15; margin-bottom: 6px; }
.sg-planning .sg-planning-sub { max-width: 300px; font-size: 15px; color: var(--slate-600); line-height: 1.45; }

.sg-planning .sg-form-card {
  border: 1px solid rgba(148,163,184,.35);
  border-radius: 16px;
  box-shadow: 0 1px 2px rgba(15,23,42,.04);
  overflow: visible;
}
.sg-planning .sg-route-input { border-bottom: 0; padding: 4px 0; }
.sg-planning .sg-route-input__line { left: 29px; top: 59px; height: 26px; opacity: .8; }
.sg-planning .sg-route-field { min-height: 62px; }
.sg-planning .sg-route-field + .sg-route-field { border-top: 0; }
.sg-planning .sg-route-field__icon { width: 52px; font-size: 19px; }
.sg-planning .sg-route-field__btn { padding: 11px 42px 11px 0; border-radius: 8px; }
.sg-planning .sg-route-field__btn:hover { background: var(--slate-50); }
.sg-planning .sg-route-field__label {
  margin-bottom: 4px;
  font-size: 12px;
  font-weight: 650;
  letter-spacing: 0;
  text-transform: none;
  color: var(--slate-600);
}
.sg-planning .sg-route-field__value { font-size: 16px; line-height: 1.25; }
.sg-planning .sg-route-field__value--ph { color: var(--slate-500); }
.sg-planning .sg-route-field__sub { font-size: 12px; }
.sg-planning .sg-route-field__clear { width: 44px; height: 44px; margin-right: 2px; }
.sg-planning .sg-swap-btn {
  right: 14px;
  width: 40px;
  height: 40px;
  border-radius: 10px;
  border-color: var(--slate-200);
  box-shadow: 0 1px 2px rgba(15,23,42,.08);
  color: var(--navy-700);
}

.sg-planning .sg-accessible-row {
  min-height: 60px;
  padding: 8px 14px 8px 16px;
  border-top: 1px solid var(--slate-100);
  border-bottom: 0;
}
.sg-planning .sg-accessible-label { gap: 10px; }
.sg-planning .sg-accessible-icon { font-size: 19px; color: var(--navy-700); }
.sg-planning .sg-accessible-title { font-size: 14px; }
.sg-planning .sg-accessible-desc { font-size: 12px; line-height: 1.3; color: var(--slate-600); }
.sg-planning .sg-toggle { width: 46px; height: 28px; border-radius: 14px; }
.sg-planning .sg-toggle__thumb { width: 22px; height: 22px; }
.sg-planning .sg-toggle.is-on .sg-toggle__thumb { transform: translateX(18px); }

.sg-planning .sg-form-actions { padding: 8px 16px 16px; }
.sg-planning .sg-calc-btn { min-height: 52px; border-radius: 12px; box-shadow: none; }
.sg-planning .sg-calc-btn:disabled { background: var(--slate-100); color: var(--slate-500); }
.sg-planning .sg-form-hint { color: var(--slate-600); }

.sg-planning .sg-quick-section { padding: 0 2px; }
.sg-planning .sg-quick-title {
  margin-bottom: 10px;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: none;
  color: var(--navy-950);
}
.sg-planning .sg-quick-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
.sg-planning .sg-quick-item {
  min-height: 76px;
  flex-direction: row;
  align-items: center;
  gap: 10px;
  padding: 12px;
  border-color: rgba(148,163,184,.3);
  border-radius: 12px;
  background: var(--white);
  text-align: left;
}
.sg-planning .sg-quick-item:hover { background: var(--teal-50); transform: none; }
.sg-planning .sg-quick-item__icon { width: auto; height: auto; background: transparent; border-radius: 0; font-size: 21px; color: var(--teal-700); }
.sg-planning .sg-quick-item__content { display: flex; flex-direction: column; min-width: 0; gap: 1px; }
.sg-planning .sg-quick-item__label { font-size: 14px; font-weight: 700; text-align: left; color: var(--navy-950); }
.sg-planning .sg-quick-item__sub { font-size: 12px; line-height: 1.25; color: var(--slate-600); }

@media (min-width: 640px) {
  .sg-planning .sg-planning-scroll { padding-top: 32px; }
  .sg-planning .sg-quick-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
/* Planning switch: the visible track remains compact while its hit target is 44px high. */
.sg-planning .sg-toggle {
  height: 44px;
  background: transparent;
  border-radius: 0;
}
.sg-planning .sg-toggle::before {
  content: '';
  position: absolute;
  inset: 8px 0;
  border-radius: 14px;
  background: var(--slate-200);
  transition: background var(--t-base);
}
.sg-planning .sg-toggle.is-on::before { background: var(--teal-600); }
.sg-planning .sg-toggle__thumb { top: 11px; z-index: 1; }

/* ============================================================
   PLANNING SCREEN вЂ” PREMIUM REDESIGN v5
   Overrides via cascade (declared after legacy rules)
   ============================================================ */

/* в”Ђв”Ђ Page canvas в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-planning {
  position: relative !important;
  height: auto !important;
  min-height: 100dvh !important;
  background: #f5f8fc !important;
  overflow-x: hidden !important;
  overflow-y: auto !important;
  -webkit-overflow-scrolling: touch;
  display: flex;
  flex-direction: column;
}

/* Allow the app shell to not clip the scrolling planning screen */
#app:has(.sg-planning) {
  overflow: visible;
  position: relative;
}

/* в”Ђв”Ђ Airport hero background в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 46vh;
  min-height: 210px;
  max-height: 380px;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
  contain: layout style;
}

.sg-hero-bg__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 62%;
  opacity: 0.22;
  filter: saturate(0.70) brightness(1.20);
  /* Prevent horizontal overflow */
  max-width: none;
}

/* Fade gradient from image to page color */
.sg-hero-bg__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(245, 248, 252, 0.28) 0%,
    rgba(245, 248, 252, 0.55) 26%,
    rgba(245, 248, 252, 0.86) 48%,
    #f5f8fc 66%,
    #f5f8fc 100%
  );
  pointer-events: none;
}

/* в”Ђв”Ђ Brand utility row (borderless) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-brandbar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  padding-top: calc(var(--safe-top) + 18px);
  padding-left: 22px;
  padding-right: 14px;
  padding-bottom: 0;
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  height: auto !important;
}

.sg-brandbar__left {
  display: flex;
  align-items: center;
  gap: 9px;
}

.sg-brandbar__logo {
  width: 32px;
  height: 32px;
  border-radius: 9px;
  object-fit: cover;
  flex-shrink: 0;
  box-shadow: 0 1px 4px rgba(6,26,53,.14);
}

.sg-brandbar__wordmark {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 22px;
  font-weight: 800;
  color: #061a35;
  letter-spacing: -0.03em;
  line-height: 1;
}

/* Circular help button */
.sg-help-btn {
  flex-shrink: 0;
  display: grid;
  place-items: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #061a35;
  color: #ffffff;
  font-size: 22px;
  cursor: pointer;
  border: none;
  transition: background var(--t-fast), transform var(--t-fast);
  box-shadow: 0 2px 8px rgba(6,26,53,.22);
}
.sg-help-btn:hover  { background: #0e2038; transform: scale(1.04); }
.sg-help-btn:active { transform: scale(0.97); }
.sg-help-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Airport context row в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-airport-ctx {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 20px 22px 0;
}

.sg-airport-ctx__icon {
  font-size: 15px;
  color: var(--teal-600);
  flex-shrink: 0;
  line-height: 1;
}

.sg-airport-ctx__text {
  font-size: 15px;
  font-weight: 600;
  color: #2d4263;
  line-height: 1.3;
  white-space: nowrap;
}

/* в”Ђв”Ђ Heading region в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-heading-region {
  position: relative;
  z-index: 2;
  padding: 36px 22px 0;
  max-width: 400px;
}

.sg-heading {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: clamp(34px, 9vw, 46px);
  font-weight: 800;
  line-height: 1.02;
  letter-spacing: -0.035em;
  color: #061a35;
  margin-bottom: 14px;
}

.sg-heading-sub {
  font-size: 17px;
  font-weight: 400;
  line-height: 1.45;
  color: #687891;
  max-width: 310px;
}

/* в”Ђв”Ђ Planning main scroll area в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-planning .sg-planning-main {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: visible !important;
  padding-bottom: 0 !important;
}

.sg-planning .sg-planning-scroll {
  width: 100%;
  max-width: 520px;
  padding: 32px 20px max(48px, var(--safe-bottom));
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* в”Ђв”Ђ Route composer surface в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-composer {
  background: #ffffff;
  border-radius: 24px;
  border: 1px solid rgba(7, 26, 51, 0.08);
  box-shadow: 0 20px 55px rgba(7, 26, 51, 0.10);
  overflow: hidden;
  margin-bottom: 28px;
}

/* в”Ђв”Ђ Journey rail (composer layout) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-journey--composer {
  display: flex;
  align-items: stretch;
  position: relative;
  border-bottom: none;
}

/* Left decorative rail */
.sg-journey--composer .sg-journey__rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
  width: 52px;
  flex-shrink: 0;
  gap: 0;
}

/* Origin dot вЂ” turquoise ring */
.sg-journey--composer .sg-journey__dot--origin {
  width: 18px !important;
  height: 18px !important;
  background: #ffffff !important;
  border: 2.5px solid #0d9488 !important;
  box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.12) !important;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 28px;
}

/* Dashed connector */
.sg-journey__connector {
  flex: 1;
  width: 2px;
  margin: 6px 0;
  background: repeating-linear-gradient(
    to bottom,
    #0d9488 0, #0d9488 4px,
    transparent 4px, transparent 10px
  );
  opacity: 0.30;
  transition: opacity 0.25s ease;
  min-height: 20px;
}

/* Filled state: both locations selected */
.sg-journey__rail.is-filled .sg-journey__connector {
  opacity: 0.72;
}

/* Destination dot вЂ” solid turquoise */
.sg-journey--composer .sg-journey__dot--dest {
  width: 18px !important;
  height: 18px !important;
  background: #0d9488 !important;
  box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.18) !important;
  border: none !important;
  border-radius: 50%;
  flex-shrink: 0;
  margin-bottom: 28px;
}

/* Fields column */
.sg-journey--composer .sg-journey__fields {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

/* Origin / destination rows */
.sg-journey--composer .sg-journey-field {
  display: flex !important;
  align-items: center !important;
  min-height: 72px !important;
  width: 100% !important;
  padding: 0 14px 0 0 !important;
  background: transparent !important;
  border: none !important;
  text-align: left !important;
  cursor: pointer !important;
  transition: background 0.12s ease !important;
  position: relative !important;
}
.sg-journey--composer .sg-journey-field:hover {
  background: rgba(245, 248, 252, 0.7) !important;
}
.sg-journey--composer .sg-journey-field:focus-visible {
  outline: 2px solid var(--teal-500);
  outline-offset: -2px;
  border-radius: 4px;
}

.sg-journey-field__label {
  font-size: 13px !important;
  font-weight: 650 !important;
  color: #687891 !important;
  line-height: 1 !important;
  margin-bottom: 5px !important;
}

.sg-journey--composer .sg-journey-field__value {
  font-size: 18px !important;
  font-weight: 600 !important;
  color: #061a35 !important;
}
.sg-journey--composer .sg-journey-field__value.is-ph {
  color: #b4c4d0 !important;
  font-weight: 400 !important;
  font-size: 17px !important;
}

.sg-journey--composer .sg-journey-clear {
  width: 40px !important;
  height: 40px !important;
  font-size: 20px !important;
}

/* Divider between origin and destination */
.sg-journey__divider {
  display: flex;
  align-items: center;
  position: relative;
  height: 0;
  z-index: 1;
}

.sg-journey__sep-line {
  position: absolute;
  left: 0; right: 0;
  height: 1px;
  background: rgba(7, 26, 51, 0.07);
  pointer-events: none;
}

/* Swap button вЂ” floating on the divider line */
.sg-journey--composer .sg-journey__swap {
  position: absolute !important;
  right: 12px !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  width: 46px !important;
  height: 46px !important;
  border-radius: 50% !important;
  display: grid !important;
  place-items: center !important;
  background: #ffffff !important;
  border: 1.5px solid rgba(7, 26, 51, 0.10) !important;
  box-shadow: 0 2px 10px rgba(7, 26, 51, 0.08) !important;
  font-size: 20px !important;
  color: #2d4263 !important;
  cursor: pointer !important;
  margin: 0 !important;
  align-self: auto !important;
  transition: background var(--t-fast), border-color var(--t-fast), box-shadow var(--t-fast) !important;
  z-index: 2;
}
.sg-journey--composer .sg-journey__swap:hover:not(:disabled) {
  background: #f0fdfa !important;
  border-color: rgba(13, 148, 136, 0.35) !important;
  color: var(--teal-700) !important;
  box-shadow: 0 4px 16px rgba(13, 148, 136, 0.14) !important;
}
.sg-journey--composer .sg-journey__swap:active:not(:disabled) {
  transform: translateY(-50%) scale(0.97) !important;
}
.sg-journey--composer .sg-journey__swap:disabled {
  opacity: 0.28 !important;
  cursor: not-allowed !important;
}
.sg-journey--composer .sg-journey__swap:focus-visible {
  outline: 2px solid var(--teal-500);
  outline-offset: 2px;
}

/* в”Ђв”Ђ Accessible route row (composer) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-access-row--composer {
  display: flex;
  align-items: center;
  min-height: 66px;
  padding: 14px 20px;
  gap: 14px;
  border-top: 1px solid rgba(7, 26, 51, 0.07);
  border-bottom: 1px solid rgba(7, 26, 51, 0.07);
  transition: background var(--t-fast);
  cursor: pointer;
}
.sg-access-row--composer:hover { background: rgba(245, 248, 252, 0.6); }

.sg-access-row--composer .sg-access-row__label {
  display: flex;
  align-items: center;
  gap: 14px;
  flex: 1;
  cursor: pointer;
  min-width: 0;
}

.sg-access-row--composer .sg-access-row__icon {
  font-size: 22px !important;
  color: #94a3b8 !important;
  flex-shrink: 0;
  transition: color var(--t-fast);
}
.sg-access-row--composer .sg-access-row__icon.is-on {
  color: var(--teal-600) !important;
}

.sg-access-row--composer .sg-access-row__text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.sg-access-row--composer .sg-access-row__title {
  font-size: 15px !important;
  font-weight: 650 !important;
  color: #061a35 !important;
  line-height: 1.2 !important;
}
.sg-access-row--composer .sg-access-row__desc {
  font-size: 13px !important;
  color: #687891 !important;
  font-weight: 400 !important;
  line-height: 1.3 !important;
  margin-top: 0 !important;
}

/* Reset the toggle for new composer context (no pseudo-element trick needed) */
.sg-composer .sg-toggle {
  position: relative;
  flex-shrink: 0;
  width: 48px !important;
  height: 28px !important;
  border-radius: 14px !important;
  background: #d1dce8 !important;
  border: none !important;
  cursor: pointer !important;
}
.sg-composer .sg-toggle::before { display: none !important; }
.sg-composer .sg-toggle.is-on { background: var(--teal-600) !important; }
.sg-composer .sg-toggle:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 3px; }
.sg-composer .sg-toggle__thumb {
  position: absolute !important;
  top: 4px !important; left: 4px !important;
  width: 20px !important; height: 20px !important;
  border-radius: 50% !important;
  background: #ffffff !important;
  box-shadow: 0 1px 4px rgba(0,0,0,.22) !important;
  transition: transform var(--t-base) !important;
}
.sg-composer .sg-toggle.is-on .sg-toggle__thumb {
  transform: translateX(20px) !important;
}

/* в”Ђв”Ђ Composer action / Calculate button в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-composer__action {
  padding: 16px 20px 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.sg-composer .sg-calc-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 10px !important;
  min-height: 56px !important;
  width: 100% !important;
  background: #061a35 !important;
  color: #ffffff !important;
  border-radius: 15px !important;
  font-family: 'Plus Jakarta Sans', sans-serif !important;
  font-size: 16px !important;
  font-weight: 700 !important;
  letter-spacing: -0.01em !important;
  border: none !important;
  cursor: pointer !important;
  transition: background var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast) !important;
  box-shadow: none !important;
}
.sg-composer .sg-calc-btn:hover:not(:disabled) {
  background: #0e2038 !important;
  transform: scale(0.99) !important;
  box-shadow: 0 6px 20px rgba(6,26,53,.28) !important;
}
.sg-composer .sg-calc-btn:active:not(:disabled) {
  transform: scale(0.98) !important;
  transition-duration: 80ms !important;
}
.sg-composer .sg-calc-btn:disabled {
  background: #e9eef5 !important;
  color: #92a2b8 !important;
  cursor: not-allowed !important;
  box-shadow: none !important;
  font-size: 15px !important;
  min-height: 56px !important;
}
.sg-composer .sg-calc-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 3px; }
.sg-calc-btn__arrow { font-size: 20px; opacity: 0.85; }

/* в”Ђв”Ђ Quick access section в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-quick-section {
  margin-bottom: 32px;
}

.sg-quick-section__title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: #061a35;
  letter-spacing: -0.01em;
  margin-bottom: 14px;
}

/* Horizontally scrollable row */
.sg-quick-scroll {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  overflow-y: visible;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
  padding-top: 2px;
  margin: 0 -2px;
  padding-left: 2px;
  padding-right: 2px;
}
.sg-quick-scroll::-webkit-scrollbar { display: none; }

/* Quick access card */
.sg-quick-card {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 10px;
  padding: 18px 10px 16px;
  width: 116px;
  min-height: 138px;
  background: #ffffff;
  border: 1px solid rgba(7, 26, 51, 0.07);
  border-radius: 18px;
  cursor: pointer;
  text-align: center;
  scroll-snap-align: start;
  transition: background var(--t-fast), border-color var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast);
  box-shadow: 0 2px 8px rgba(7, 26, 51, 0.05);
}
.sg-quick-card:hover {
  background: #f0fdfa;
  border-color: rgba(13, 148, 136, 0.25);
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(7, 26, 51, 0.09);
}
.sg-quick-card:active { transform: scale(0.97); }
.sg-quick-card:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

.sg-quick-card__icon {
  font-size: 28px;
  color: var(--teal-600);
  line-height: 1;
  flex-shrink: 0;
}

.sg-quick-card__icon-wrap {
  font-size: 28px;
  color: var(--teal-600);
  line-height: 1;
  flex-shrink: 0;
  display: grid;
  place-items: center;
}
.sg-quick-card:hover .sg-quick-card__icon,
.sg-quick-card:hover .sg-quick-card__icon-wrap { color: var(--teal-700); }

.sg-quick-card__name {
  font-size: 13px;
  font-weight: 700;
  color: #061a35;
  line-height: 1.25;
  letter-spacing: -0.01em;
}

.sg-quick-card__sub {
  font-size: 11px;
  color: #687891;
  font-weight: 400;
  line-height: 1.35;
}

/* в”Ђв”Ђ Entrance animations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
@keyframes sg-fade-up {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes sg-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.sg-planning .sg-brandbar    { animation: sg-fade-in 0.22s ease both; }
.sg-planning .sg-airport-ctx { animation: sg-fade-in 0.22s ease both; animation-delay: 30ms; }
.sg-planning .sg-heading-region { animation: sg-fade-up 0.26s ease both; animation-delay: 60ms; }
.sg-planning .sg-composer    { animation: sg-fade-up 0.28s ease both; animation-delay: 100ms; }
.sg-planning .sg-quick-section { animation: sg-fade-up 0.26s ease both; animation-delay: 140ms; }

@media (prefers-reduced-motion: reduce) {
  .sg-planning .sg-brandbar,
  .sg-planning .sg-airport-ctx,
  .sg-planning .sg-heading-region,
  .sg-planning .sg-composer,
  .sg-planning .sg-quick-section {
    animation: none !important;
  }
}

/* в”Ђв”Ђ Responsive breakpoints в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */

/* Narrow (в‰¤380px) */
@media (max-width: 380px) {
  .sg-brandbar          { padding-left: 16px !important; padding-right: 10px !important; }
  .sg-airport-ctx       { padding-left: 16px !important; }
  .sg-heading-region    { padding-left: 16px !important; padding-right: 16px !important; }
  .sg-planning .sg-planning-scroll { padding-left: 16px !important; padding-right: 16px !important; }
  .sg-heading           { font-size: clamp(30px, 9vw, 36px) !important; }
  .sg-quick-card        { width: 104px !important; }
}

/* Standard mobile (381вЂ“520px) */
@media (min-width: 381px) and (max-width: 520px) {
  .sg-planning .sg-planning-scroll { padding-left: 20px !important; padding-right: 20px !important; }
}

/* Desktop вЂ” centered panel */
@media (min-width: 521px) {
  .sg-planning { align-items: center; }
  .sg-brandbar {
    width: 100%;
    max-width: 520px;
    padding-left: 24px !important;
    padding-right: 16px !important;
    align-self: center;
  }
  .sg-airport-ctx {
    width: 100%;
    max-width: 520px;
    padding-left: 24px !important;
    align-self: center;
  }
  .sg-heading-region {
    width: 100%;
    max-width: 520px;
    padding-left: 24px !important;
    align-self: center;
  }
  .sg-planning .sg-planning-main {
    width: 100%;
    max-width: 520px;
    align-self: center;
  }
  .sg-planning .sg-planning-scroll {
    padding-left: 24px !important;
    padding-right: 24px !important;
  }
  .sg-quick-card  { width: 118px !important; }
  .sg-hero-bg     { left: 50%; transform: translateX(-50%); max-width: 520px; }
}

/* Tall viewports */
@media (min-height: 900px) {
  .sg-heading-region { padding-top: 48px !important; }
  .sg-planning .sg-planning-scroll { padding-top: 40px !important; }
}

/* ============================================================
   PREMIUM REDESIGN v6 вЂ” ROUTE SEARCH FLOW
   Appended after all existing rules (cascade priority).
   ============================================================ */

/* в”Ђв”Ђ Journey field: floor/category chip pill в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-journey-field__chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  margin-top: 6px;
  padding: 4px 10px 4px 8px;
  background: rgba(13, 148, 136, 0.09);
  color: #0d9488;
  border-radius: 99px;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 85%;
}
.sg-journey-field__chip iconify-icon {
  font-size: 13px;
  flex-shrink: 0;
}

/* в”Ђв”Ђ Hero heading вЂ” match reference exactly в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-heading {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: clamp(36px, 10vw, 48px) !important;
  font-weight: 800 !important;
  line-height: 1.00 !important;
  letter-spacing: -0.04em !important;
  color: #061a35 !important;
  margin-bottom: 16px !important;
}
.sg-heading-sub {
  font-size: 16px !important;
  font-weight: 400 !important;
  line-height: 1.5 !important;
  color: #687891 !important;
  max-width: 280px !important;
}
.sg-heading-region {
  padding: 28px 22px 0 !important;
}

/* в”Ђв”Ђ Airport context в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-airport-ctx {
  padding: 16px 22px 0 !important;
}
.sg-airport-ctx__text {
  font-size: 14px !important;
  font-weight: 600 !important;
  color: #2d4263 !important;
}
.sg-airport-ctx__icon {
  font-size: 14px !important;
  color: var(--teal-600) !important;
}

/* в”Ђв”Ђ Brand bar в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-brandbar__wordmark {
  font-family: 'Plus Jakarta Sans', sans-serif !important;
  font-size: 22px !important;
  font-weight: 800 !important;
  color: #061a35 !important;
  letter-spacing: -0.025em !important;
  line-height: 1 !important;
}
.sg-brandbar__logo {
  width: 40px !important;
  height: 40px !important;
  border-radius: 10px !important;
  object-fit: cover !important;
  flex-shrink: 0 !important;
  box-shadow: 0 2px 6px rgba(6,26,53,.14) !important;
}
.sg-brandbar {
  padding-top: calc(var(--safe-top) + 16px) !important;
  padding-left: 20px !important;
  padding-right: 14px !important;
}
.sg-help-btn {
  width: 42px !important;
  height: 42px !important;
  font-size: 20px !important;
  border-radius: 50% !important;
  background: #061a35 !important;
  color: #fff !important;
  box-shadow: 0 2px 10px rgba(6,26,53,.22) !important;
}

/* в”Ђв”Ђ Composer card: match reference spacing в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-composer {
  background: #ffffff !important;
  border-radius: 20px !important;
  border: 1px solid rgba(7, 26, 51, 0.07) !important;
  box-shadow: 0 4px 24px rgba(7, 26, 51, 0.08), 0 1px 4px rgba(7,26,51,.04) !important;
  overflow: hidden !important;
  margin-bottom: 24px !important;
}
.sg-planning .sg-planning-scroll {
  padding-top: 28px !important;
  gap: 0 !important;
}

/* в”Ђв”Ђ Journey fields: taller rows matching reference в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-journey--composer .sg-journey-field {
  min-height: 76px !important;
  padding: 0 14px 0 0 !important;
}
.sg-journey-field__label {
  font-size: 12px !important;
  font-weight: 600 !important;
  color: #687891 !important;
  line-height: 1 !important;
  margin-bottom: 4px !important;
}
.sg-journey--composer .sg-journey-field__value {
  font-size: 19px !important;
  font-weight: 700 !important;
  color: #061a35 !important;
  line-height: 1.2 !important;
}
.sg-journey--composer .sg-journey-field__value.is-ph {
  color: #b4c4d0 !important;
  font-weight: 400 !important;
  font-size: 17px !important;
}

/* Clear X button вЂ” gray circle matching reference */
.sg-journey-clear {
  width: 34px !important;
  height: 34px !important;
  border-radius: 50% !important;
  display: grid !important;
  place-items: center !important;
  background: #e8eef5 !important;
  color: #687891 !important;
  font-size: 17px !important;
  flex-shrink: 0 !important;
  cursor: pointer !important;
  transition: background var(--t-fast) !important;
}
.sg-journey-clear:hover { background: #d1dce8 !important; }

/* Swap button: exact match to reference */
.sg-journey--composer .sg-journey__swap {
  position: absolute !important;
  right: 14px !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  width: 42px !important;
  height: 42px !important;
  border-radius: 50% !important;
  display: grid !important;
  place-items: center !important;
  background: #ffffff !important;
  border: 1.5px solid rgba(7, 26, 51, 0.10) !important;
  box-shadow: 0 2px 8px rgba(7, 26, 51, 0.08) !important;
  font-size: 19px !important;
  color: #2d4263 !important;
  cursor: pointer !important;
  z-index: 2 !important;
  transition: background var(--t-fast), box-shadow var(--t-fast) !important;
}
.sg-journey--composer .sg-journey__swap:hover:not(:disabled) {
  background: #f0fdfa !important;
  border-color: rgba(13,148,136,.3) !important;
  color: var(--teal-700) !important;
  box-shadow: 0 4px 16px rgba(13,148,136,.14) !important;
}
.sg-journey--composer .sg-journey__swap:disabled {
  opacity: 0.25 !important;
  cursor: not-allowed !important;
}

/* Rail dots */
.sg-journey--composer .sg-journey__dot--origin {
  width: 16px !important;
  height: 16px !important;
  background: #ffffff !important;
  border: 2.5px solid #0d9488 !important;
  box-shadow: 0 0 0 3px rgba(13,148,136,.12) !important;
  border-radius: 50% !important;
  flex-shrink: 0 !important;
  margin-top: 30px !important;
}
.sg-journey--composer .sg-journey__dot--dest {
  width: 16px !important;
  height: 16px !important;
  background: #b4c4d0 !important;
  border: none !important;
  box-shadow: none !important;
  border-radius: 50% !important;
  flex-shrink: 0 !important;
  margin-bottom: 30px !important;
}
.sg-journey--composer .sg-journey__rail {
  width: 48px !important;
  padding: 0 !important;
}

/* Accessible route row */
.sg-access-row--composer {
  min-height: 64px !important;
  padding: 12px 18px !important;
  border-top: 1px solid rgba(7,26,51,.06) !important;
  border-bottom: 1px solid rgba(7,26,51,.06) !important;
}
.sg-access-row--composer .sg-access-row__title {
  font-size: 15px !important;
  font-weight: 600 !important;
  color: #061a35 !important;
}
.sg-access-row--composer .sg-access-row__desc {
  font-size: 13px !important;
  color: #687891 !important;
}
.sg-access-row--composer .sg-access-row__icon {
  font-size: 22px !important;
}

/* Calculate button */
.sg-composer__action {
  padding: 14px 18px 18px !important;
}
.sg-composer .sg-calc-btn {
  min-height: 54px !important;
  font-size: 16px !important;
  border-radius: 13px !important;
  background: #061a35 !important;
  color: #ffffff !important;
}
.sg-composer .sg-calc-btn:disabled {
  background: #edf1f7 !important;
  color: #8fa4b8 !important;
  min-height: 54px !important;
}
.sg-form-hint {
  font-size: 13px !important;
  color: #8fa4b8 !important;
  text-align: center !important;
}

/* в”Ђв”Ђ Quick access section вЂ” exact reference match в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-quick-section {
  margin-bottom: 28px !important;
}
.sg-quick-section__title {
  font-family: 'Plus Jakarta Sans', sans-serif !important;
  font-size: 15px !important;
  font-weight: 700 !important;
  color: #061a35 !important;
  letter-spacing: -0.01em !important;
  margin-bottom: 12px !important;
}

.sg-quick-scroll {
  display: flex !important;
  gap: 10px !important;
  overflow-x: auto !important;
  overflow-y: visible !important;
  scroll-snap-type: x mandatory !important;
  -webkit-overflow-scrolling: touch !important;
  scrollbar-width: none !important;
  padding-bottom: 4px !important;
  margin: 0 -2px !important;
  padding-left: 2px !important;
  padding-right: 2px !important;
}
.sg-quick-scroll::-webkit-scrollbar { display: none !important; }

/* Quick card вЂ” sized to fit 4 across a ~375px screen with gaps */
.sg-quick-card {
  flex-shrink: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: flex-start !important;
  gap: 8px !important;
  padding: 16px 8px 14px !important;
  width: 106px !important;
  min-height: 130px !important;
  background: #ffffff !important;
  border: 1px solid rgba(7, 26, 51, 0.07) !important;
  border-radius: 16px !important;
  cursor: pointer !important;
  text-align: center !important;
  scroll-snap-align: start !important;
  box-shadow: 0 1px 4px rgba(7,26,51,.06) !important;
  transition: background var(--t-fast), border-color var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast) !important;
}
.sg-quick-card:hover {
  background: #f0fdfa !important;
  border-color: rgba(13,148,136,.22) !important;
  transform: translateY(-2px) !important;
  box-shadow: 0 4px 14px rgba(7,26,51,.09) !important;
}
.sg-quick-card:active { transform: scale(0.97) !important; }
.sg-quick-card:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* Icon: naked teal icon, no background container вЂ” matches reference */
.sg-quick-card__icon-wrap {
  width: auto !important;
  height: auto !important;
  border-radius: 0 !important;
  background: transparent !important;
  display: grid !important;
  place-items: center !important;
  font-size: 32px !important;
  color: var(--teal-600) !important;
  flex-shrink: 0 !important;
  line-height: 1 !important;
  transition: color var(--t-fast) !important;
  box-shadow: none !important;
}
.sg-quick-card:hover .sg-quick-card__icon-wrap {
  background: transparent !important;
  color: var(--teal-700) !important;
}

/* Name + subtitle */
.sg-quick-card__name {
  font-size: 13px !important;
  font-weight: 700 !important;
  color: #061a35 !important;
  line-height: 1.2 !important;
  letter-spacing: -0.01em !important;
  text-align: center !important;
  word-break: keep-all !important;
  hyphens: none !important;
}
.sg-quick-card__sub {
  font-size: 11px !important;
  color: #687891 !important;
  font-weight: 400 !important;
  line-height: 1.3 !important;
  text-align: center !important;
}

/* Responsive: wider screens get wider cards */
@media (min-width: 381px) and (max-width: 520px) {
  .sg-quick-card { width: 110px !important; }
}
@media (min-width: 521px) {
  .sg-quick-card { width: 118px !important; }
}

/* в”Ђв”Ђ Search sheet: larger title в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-title {
  font-family: 'Plus Jakarta Sans', sans-serif !important;
  font-size: 18px !important;
  font-weight: 800 !important;
  color: #061a35 !important;
  letter-spacing: -0.02em !important;
}

/* в”Ђв”Ђ Search sheet: circular dark close button в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-close-btn {
  flex-shrink: 0;
  display: grid;
  place-items: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #061a35;
  color: #ffffff;
  font-size: 20px;
  border: none;
  cursor: pointer;
  transition: background var(--t-fast), transform var(--t-fast);
}
.sg-search-close-btn:hover  { background: #0e2038; }
.sg-search-close-btn:active { transform: scale(0.95); }
.sg-search-close-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Search bar: taller, more premium в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-input-wrap {
  display: flex !important;
  align-items: center !important;
  gap: 10px !important;
  min-height: 52px !important;
  margin: 0 16px !important;
  background: #f8fafc !important;
  border: 1.5px solid rgba(7, 26, 51, 0.10) !important;
  border-radius: 14px !important;
  padding: 0 14px !important;
  flex-shrink: 0 !important;
  box-shadow: 0 1px 3px rgba(7, 26, 51, 0.05) !important;
  transition: border-color var(--t-fast), box-shadow var(--t-fast), background var(--t-fast) !important;
}
.sg-search-input-wrap:focus-within {
  border-color: var(--teal-500) !important;
  box-shadow: 0 0 0 3px rgba(20, 184, 166, 0.12) !important;
  background: #ffffff !important;
}
.sg-search-input-icon {
  font-size: 18px !important;
  color: #94a3b8 !important;
  flex-shrink: 0;
  transition: color var(--t-fast);
}
.sg-search-input-wrap:focus-within .sg-search-input-icon {
  color: var(--teal-600) !important;
}
.sg-search-input {
  flex: 1 !important;
  background: transparent !important;
  border: none !important;
  outline: none !important;
  font-size: 15px !important;
  font-weight: 500 !important;
  color: #061a35 !important;
}
.sg-search-input::placeholder { color: #b4c4d0 !important; }

/* в”Ђв”Ђ Search bar: clear button в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-clear-btn {
  flex-shrink: 0;
  display: grid;
  place-items: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #e2e8f0;
  color: #64748b;
  font-size: 16px;
  border: none;
  cursor: pointer;
  transition: background var(--t-fast), color var(--t-fast);
}
.sg-search-clear-btn:hover  { background: #cbd5e1; color: #334155; }
.sg-search-clear-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Filter chips: icon-prefixed, active teal state в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-quick-chips {
  display: flex !important;
  gap: 7px !important;
  padding: 12px 16px 8px !important;
  overflow-x: auto !important;
  scrollbar-width: none !important;
  flex-shrink: 0 !important;
}
.sg-quick-chips::-webkit-scrollbar { display: none !important; }

.sg-chip {
  flex-shrink: 0 !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 6px !important;
  height: 34px !important;
  padding: 0 13px !important;
  border-radius: 17px !important;
  border: 1.5px solid rgba(7, 26, 51, 0.12) !important;
  background: #ffffff !important;
  font-size: 13px !important;
  font-weight: 600 !important;
  color: #475569 !important;
  white-space: nowrap !important;
  cursor: pointer !important;
  transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast), box-shadow var(--t-fast) !important;
}
.sg-chip iconify-icon {
  font-size: 14px !important;
  flex-shrink: 0;
}
.sg-chip:hover:not(.is-active) {
  background: #f0fdfa !important;
  border-color: rgba(13, 148, 136, 0.30) !important;
  color: var(--teal-700) !important;
}
.sg-chip.is-active {
  background: var(--teal-600) !important;
  border-color: var(--teal-600) !important;
  color: #ffffff !important;
  box-shadow: 0 2px 8px rgba(13, 148, 136, 0.28) !important;
}
.sg-chip.is-active iconify-icon { color: rgba(255,255,255,0.9) !important; }
.sg-chip:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Search group header with icon + accent line в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-group {
  padding: 14px 16px 4px !important;
}
.sg-search-group__header {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 6px;
}
.sg-search-group__header-accent {
  width: 3px;
  height: 14px;
  border-radius: 2px;
  background: var(--teal-500);
  flex-shrink: 0;
  opacity: 0.7;
}
.sg-search-group__header-icon {
  font-size: 13px;
  color: var(--teal-600);
  flex-shrink: 0;
}
.sg-search-group__label {
  font-size: 11px !important;
  font-weight: 800 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.09em !important;
  color: #64748b !important;
  display: block;
}

/* в”Ђв”Ђ Search item row: premium в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-item {
  display: flex !important;
  align-items: center !important;
  gap: 12px !important;
  width: 100% !important;
  min-height: 64px !important;
  padding: 10px 10px 10px 4px !important;
  border-radius: 12px !important;
  text-align: left !important;
  cursor: pointer !important;
  transition: background var(--t-fast) !important;
}
.sg-search-item:hover  { background: rgba(13,148,136,0.05) !important; }
.sg-search-item:active { background: rgba(13,148,136,0.09) !important; }
.sg-search-item:focus-visible { outline: 2px solid var(--teal-500); outline-offset: -2px; border-radius: 12px; }

.sg-search-item__icon {
  width: 44px !important;
  height: 44px !important;
  border-radius: 12px !important;
  background: color-mix(in srgb, var(--item-color, #64748b) 12%, #fff) !important;
  display: grid !important;
  place-items: center !important;
  font-size: 20px !important;
  color: var(--item-color, #64748b) !important;
  flex-shrink: 0 !important;
}
@supports not (color: color-mix(in srgb, red, blue)) {
  .sg-search-item__icon { background: #f1f5f9 !important; }
}
.sg-search-item__body {
  flex: 1 !important;
  min-width: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 4px !important;
}
.sg-search-item__name {
  font-size: 14px !important;
  font-weight: 600 !important;
  color: #061a35 !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  line-height: 1.25 !important;
}
.sg-search-item__meta {
  display: flex !important;
  align-items: center !important;
  gap: 5px !important;
  flex-wrap: wrap !important;
}
.sg-search-item__floor-badge {
  display: inline-flex;
  align-items: center;
  padding: 1px 7px;
  background: rgba(13, 148, 136, 0.09);
  color: #0d9488;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 600;
  line-height: 1.5;
  white-space: nowrap;
}
.sg-search-item__access-badge {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 1px 7px;
  background: rgba(20, 184, 166, 0.08);
  color: var(--teal-600);
  border-radius: 99px;
  font-size: 11px;
  font-weight: 600;
  line-height: 1.5;
}
.sg-search-item__access-badge iconify-icon { font-size: 11px; }
.sg-search-item__arrow {
  font-size: 16px !important;
  color: #c8d8e8 !important;
  flex-shrink: 0 !important;
  transition: color var(--t-fast), transform var(--t-fast) !important;
}
.sg-search-item:hover .sg-search-item__arrow {
  color: var(--teal-500) !important;
  transform: translateX(2px) !important;
}

/* в”Ђв”Ђ Empty state: illustrated + polished в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-empty {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  gap: 0 !important;
  padding: 48px 28px 40px !important;
  text-align: center !important;
}
.sg-search-empty__illustration {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 130px;
  height: 130px;
  margin-bottom: 20px;
}
.sg-search-empty__glow {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(13,148,136,0.10) 0%, transparent 70%);
}
.sg-search-empty__icon {
  font-size: 54px;
  color: #94a3b8;
  position: relative;
  z-index: 1;
}
.sg-search-empty__svg {
  width: 130px;
  height: 98px;
  position: relative;
  z-index: 1;
}
.sg-search-empty__title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 16px !important;
  font-weight: 700 !important;
  color: #061a35 !important;
  margin-bottom: 6px !important;
  letter-spacing: -0.01em;
}
.sg-search-empty__sub {
  font-size: 13px !important;
  color: #687891 !important;
  font-weight: 400 !important;
  line-height: 1.5 !important;
  max-width: 240px;
}

/* в”Ђв”Ђ Handle pill в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-handle {
  width: 36px !important;
  height: 4px !important;
  border-radius: 2px !important;
  background: #d1dce8 !important;
  margin: 10px auto 2px !important;
}

/* в”Ђв”Ђ Search sheet header в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-header {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  padding: 14px 18px 12px !important;
  flex-shrink: 0 !important;
}


/* в”Ђв”Ђ Quick access: icon in a tinted circle в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-quick-card__icon-wrap {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  background: rgba(13, 148, 136, 0.10);
  display: grid;
  place-items: center;
  font-size: 26px;
  color: var(--teal-600);
  flex-shrink: 0;
  transition: background var(--t-fast);
}
.sg-quick-card:hover .sg-quick-card__icon-wrap {
  background: rgba(13, 148, 136, 0.18);
  color: var(--teal-700);
}

/* Quick card: tighten layout, allow 2-line name */
.sg-quick-card__name {
  font-size: 13px;
  font-weight: 700;
  color: #061a35;
  line-height: 1.2;
  letter-spacing: -0.01em;
  text-align: center;
  word-break: keep-all;
}
.sg-quick-card__sub {
  font-size: 11px;
  color: #687891;
  font-weight: 400;
  line-height: 1.3;
  text-align: center;
}

/* в”Ђв”Ђ Search sheet: larger title в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-title {
  font-family: 'Plus Jakarta Sans', sans-serif !important;
  font-size: 18px !important;
  font-weight: 800 !important;
  color: #061a35 !important;
  letter-spacing: -0.02em !important;
}

/* в”Ђв”Ђ Search sheet: circular dark close button в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-close-btn {
  flex-shrink: 0;
  display: grid;
  place-items: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #061a35;
  color: #ffffff;
  font-size: 20px;
  border: none;
  cursor: pointer;
  transition: background var(--t-fast), transform var(--t-fast);
}
.sg-search-close-btn:hover  { background: #0e2038; }
.sg-search-close-btn:active { transform: scale(0.95); }
.sg-search-close-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Search bar: taller, more premium в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-input-wrap {
  display: flex !important;
  align-items: center !important;
  gap: 10px !important;
  min-height: 52px !important;
  margin: 0 16px !important;
  background: #f8fafc !important;
  border: 1.5px solid rgba(7, 26, 51, 0.10) !important;
  border-radius: 14px !important;
  padding: 0 14px !important;
  flex-shrink: 0 !important;
  box-shadow: 0 1px 3px rgba(7, 26, 51, 0.05) !important;
  transition: border-color var(--t-fast), box-shadow var(--t-fast), background var(--t-fast) !important;
}
.sg-search-input-wrap:focus-within {
  border-color: var(--teal-500) !important;
  box-shadow: 0 0 0 3px rgba(20, 184, 166, 0.12) !important;
  background: #ffffff !important;
}
.sg-search-input-icon {
  font-size: 18px !important;
  color: #94a3b8 !important;
  flex-shrink: 0;
  transition: color var(--t-fast);
}
.sg-search-input-wrap:focus-within .sg-search-input-icon {
  color: var(--teal-600) !important;
}
.sg-search-input {
  flex: 1 !important;
  background: transparent !important;
  border: none !important;
  outline: none !important;
  font-size: 15px !important;
  font-weight: 500 !important;
  color: #061a35 !important;
}
.sg-search-input::placeholder { color: #b4c4d0 !important; }

/* в”Ђв”Ђ Search bar: clear button в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-clear-btn {
  flex-shrink: 0;
  display: grid;
  place-items: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #e2e8f0;
  color: #64748b;
  font-size: 16px;
  border: none;
  cursor: pointer;
  transition: background var(--t-fast), color var(--t-fast);
}
.sg-search-clear-btn:hover  { background: #cbd5e1; color: #334155; }
.sg-search-clear-btn:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Filter chips: icon-prefixed, active teal state в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-quick-chips {
  display: flex !important;
  gap: 7px !important;
  padding: 12px 16px 8px !important;
  overflow-x: auto !important;
  scrollbar-width: none !important;
  flex-shrink: 0 !important;
}
.sg-quick-chips::-webkit-scrollbar { display: none !important; }

.sg-chip {
  flex-shrink: 0 !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 6px !important;
  height: 34px !important;
  padding: 0 13px !important;
  border-radius: 17px !important;
  border: 1.5px solid rgba(7, 26, 51, 0.12) !important;
  background: #ffffff !important;
  font-size: 13px !important;
  font-weight: 600 !important;
  color: #475569 !important;
  white-space: nowrap !important;
  cursor: pointer !important;
  transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast), box-shadow var(--t-fast) !important;
}
.sg-chip iconify-icon {
  font-size: 14px !important;
  flex-shrink: 0;
}
.sg-chip:hover:not(.is-active) {
  background: #f0fdfa !important;
  border-color: rgba(13, 148, 136, 0.30) !important;
  color: var(--teal-700) !important;
}
.sg-chip.is-active {
  background: var(--teal-600) !important;
  border-color: var(--teal-600) !important;
  color: #ffffff !important;
  box-shadow: 0 2px 8px rgba(13, 148, 136, 0.28) !important;
}
.sg-chip.is-active iconify-icon { color: rgba(255,255,255,0.9) !important; }
.sg-chip:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

/* в”Ђв”Ђ Search group header with icon + accent line в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-group {
  padding: 14px 16px 4px !important;
}

.sg-search-group__header {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 6px;
}

.sg-search-group__header-accent {
  width: 3px;
  height: 14px;
  border-radius: 2px;
  background: var(--teal-500);
  flex-shrink: 0;
  opacity: 0.7;
}

.sg-search-group__header-icon {
  font-size: 13px;
  color: var(--teal-600);
  flex-shrink: 0;
}

.sg-search-group__label {
  font-size: 11px !important;
  font-weight: 800 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.09em !important;
  color: #64748b !important;
  display: block;
}

/* в”Ђв”Ђ Search item row: premium в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-item {
  display: flex !important;
  align-items: center !important;
  gap: 12px !important;
  width: 100% !important;
  min-height: 64px !important;
  padding: 10px 10px 10px 4px !important;
  border-radius: 12px !important;
  text-align: left !important;
  cursor: pointer !important;
  transition: background var(--t-fast) !important;
}
.sg-search-item:hover  { background: rgba(13,148,136,0.05) !important; }
.sg-search-item:active { background: rgba(13,148,136,0.09) !important; }
.sg-search-item:focus-visible { outline: 2px solid var(--teal-500); outline-offset: -2px; border-radius: 12px; }

/* Tinted icon circle using CSS custom property --item-color */
.sg-search-item__icon {
  width: 44px !important;
  height: 44px !important;
  border-radius: 12px !important;
  background: color-mix(in srgb, var(--item-color, #64748b) 12%, #fff) !important;
  display: grid !important;
  place-items: center !important;
  font-size: 20px !important;
  color: var(--item-color, #64748b) !important;
  flex-shrink: 0 !important;
}
/* Fallback for browsers without color-mix */
@supports not (color: color-mix(in srgb, red, blue)) {
  .sg-search-item__icon { background: #f1f5f9 !important; }
}

.sg-search-item__body {
  flex: 1 !important;
  min-width: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 4px !important;
}

.sg-search-item__name {
  font-size: 14px !important;
  font-weight: 600 !important;
  color: #061a35 !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  line-height: 1.25 !important;
}

.sg-search-item__meta {
  display: flex !important;
  align-items: center !important;
  gap: 5px !important;
  flex-wrap: wrap !important;
}

/* Floor badge pill */
.sg-search-item__floor-badge {
  display: inline-flex;
  align-items: center;
  padding: 1px 7px;
  background: rgba(13, 148, 136, 0.09);
  color: #0d9488;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 600;
  line-height: 1.5;
  white-space: nowrap;
}

/* Accessible badge */
.sg-search-item__access-badge {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 1px 7px;
  background: rgba(20, 184, 166, 0.08);
  color: var(--teal-600);
  border-radius: 99px;
  font-size: 11px;
  font-weight: 600;
  line-height: 1.5;
}
.sg-search-item__access-badge iconify-icon { font-size: 11px; }

.sg-search-item__arrow {
  font-size: 16px !important;
  color: #c8d8e8 !important;
  flex-shrink: 0 !important;
  transition: color var(--t-fast), transform var(--t-fast) !important;
}
.sg-search-item:hover .sg-search-item__arrow {
  color: var(--teal-500) !important;
  transform: translateX(2px) !important;
}

/* в”Ђв”Ђ Empty state: illustrated + polished в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-empty {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  gap: 0 !important;
  padding: 48px 28px 40px !important;
  text-align: center !important;
}

.sg-search-empty__illustration {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120px;
  height: 120px;
  margin-bottom: 20px;
}

.sg-search-empty__glow {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(13, 148, 136, 0.10) 0%, transparent 70%);
}

.sg-search-empty__icon {
  font-size: 52px;
  color: #94a3b8;
  position: relative;
  z-index: 1;
}

.sg-search-empty__svg {
  width: 120px;
  height: 90px;
  position: relative;
  z-index: 1;
}

.sg-search-empty__title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 16px !important;
  font-weight: 700 !important;
  color: #061a35 !important;
  margin-bottom: 6px !important;
  letter-spacing: -0.01em;
}

.sg-search-empty__sub {
  font-size: 13px !important;
  color: #687891 !important;
  font-weight: 400 !important;
  line-height: 1.5 !important;
  max-width: 240px;
}

/* в”Ђв”Ђ Handle pill: slightly bigger and more visible в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-handle {
  width: 36px !important;
  height: 4px !important;
  border-radius: 2px !important;
  background: #d1dce8 !important;
  margin: 10px auto 2px !important;
}

/* в”Ђв”Ђ Search sheet: tighter padding on header в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-search-header {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  padding: 14px 18px 12px !important;
  flex-shrink: 0 !important;
}
/* ============================================================
   INITIAL ROUTE PLANNING вЂ” REFERENCE-FIDELITY OVERRIDE
   Scoped to the planning entry screen only. Preserve behavior,
   increase scale/breathing room to match the supplied mobile comp.
   ============================================================ */

.sg-planning {
  --page-background: #f5f8fc;
  --surface: #ffffff;
  --navy-primary: #061a35;
  --navy-secondary: #102a4d;
  --turquoise-primary: #009f98;
  --turquoise-soft: #e3f7f4;
  --text-primary: #071a33;
  --text-secondary: #667894;
  --border-subtle: #dce5ef;
  --disabled-surface: #e8eef5;
  --disabled-text: #7f90a8;
  font-family: "Manrope", "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
  background: var(--page-background) !important;
}

#app:has(.sg-planning) { background: var(--page-background) !important; }

.sg-hero-bg { height: 470px !important; min-height: 430px !important; max-height: 520px !important; }
.sg-hero-bg__img { object-position: center top !important; opacity: 0.28 !important; filter: saturate(0.72) brightness(1.14) !important; }
.sg-hero-bg__overlay {
  background: linear-gradient(180deg, rgba(245,248,252,.20) 0%, rgba(245,248,252,.48) 32%, rgba(245,248,252,.82) 55%, #f5f8fc 76%, #f5f8fc 100%) !important;
}

.sg-brandbar, .sg-airport-ctx, .sg-heading-region { width: 100% !important; max-width: 430px !important; margin-inline: auto !important; }
.sg-brandbar { padding: calc(var(--safe-top) + 22px) 26px 0 !important; }
.sg-brandbar__left { gap: 16px !important; }
.sg-brandbar__logo {
  width: 50px !important; height: 50px !important; border-radius: 15px !important; background: #fff !important;
  box-shadow: 0 14px 30px rgba(7,26,51,.10), 0 2px 8px rgba(7,26,51,.06) !important;
}
.sg-brandbar__wordmark {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: clamp(25px, 7.2vw, 29px) !important; font-weight: 800 !important; letter-spacing: -.04em !important; color: var(--navy-primary) !important;
}
.sg-help-btn {
  width: 52px !important; height: 52px !important; font-size: 25px !important; background: var(--navy-primary) !important;
  box-shadow: 0 16px 34px rgba(6,26,53,.20), 0 3px 8px rgba(6,26,53,.12) !important;
}

.sg-airport-ctx { gap: 10px !important; padding: 28px 26px 0 !important; }
.sg-airport-ctx__icon { font-size: 18px !important; color: var(--turquoise-primary) !important; }
.sg-airport-ctx__text { font-size: 17px !important; font-weight: 600 !important; color: var(--navy-secondary) !important; letter-spacing: -.01em !important; }

.sg-heading-region { padding: 54px 26px 0 !important; }
.sg-heading {
  max-width: 340px !important; font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: clamp(42px, 11.5vw, 50px) !important; font-weight: 800 !important; line-height: .98 !important; letter-spacing: -.045em !important;
  color: var(--navy-primary) !important; margin: 0 0 20px !important;
}
.sg-heading-sub { max-width: 330px !important; font-size: 18px !important; line-height: 1.45 !important; font-weight: 500 !important; color: var(--text-secondary) !important; margin: 0 !important; }

.sg-planning .sg-planning-main { width: 100% !important; }
.sg-planning .sg-planning-scroll { max-width: 430px !important; margin-inline: auto !important; padding: 38px 26px max(48px, var(--safe-bottom)) !important; overflow: visible !important; }
.sg-composer {
  border-radius: 28px !important; border: 1px solid var(--border-subtle) !important; background: var(--surface) !important;
  box-shadow: 0 24px 60px rgba(7,26,51,.10), 0 4px 12px rgba(7,26,51,.04) !important; margin-bottom: 36px !important;
}

.sg-journey--composer .sg-journey__rail { width: 58px !important; }
.sg-journey--composer .sg-journey__dot--origin {
  width: 26px !important; height: 26px !important; margin-top: 34px !important; border: 5px solid var(--turquoise-primary) !important; background: #fff !important; box-shadow: none !important;
}
.sg-journey--composer .sg-journey__dot--dest {
  width: 26px !important; height: 26px !important; margin-bottom: 34px !important; background: #b9c7d8 !important; border: 6px solid #edf3f9 !important; box-shadow: none !important;
}
.sg-journey__connector {
  width: 2px !important; margin: 9px 0 !important; min-height: 66px !important;
  background: repeating-linear-gradient(to bottom, #9fb1c7 0, #9fb1c7 5px, transparent 5px, transparent 13px) !important; opacity: .75 !important;
}
.sg-journey__rail.is-filled .sg-journey__connector {
  background: repeating-linear-gradient(to bottom, var(--turquoise-primary) 0, var(--turquoise-primary) 5px, transparent 5px, transparent 13px) !important; opacity: .65 !important;
}
.sg-journey--composer .sg-journey-field { min-height: 112px !important; padding: 0 18px 0 0 !important; }
.sg-journey-field__inner { gap: 0 !important; padding-right: 8px !important; }
.sg-journey-field__label { font-size: 15px !important; font-weight: 700 !important; line-height: 1.15 !important; color: #657792 !important; margin-bottom: 10px !important; }
.sg-journey--composer .sg-journey-field__value { font-size: 23px !important; font-weight: 750 !important; line-height: 1.16 !important; letter-spacing: -.025em !important; color: var(--text-primary) !important; }
.sg-journey--composer .sg-journey-field__value.is-ph { font-size: 20px !important; font-weight: 500 !important; letter-spacing: -.02em !important; color: #93a2b7 !important; }
.sg-journey-field__chip {
  height: 34px !important; max-width: min(220px, 86%) !important; margin-top: 12px !important; padding: 0 13px 0 11px !important; gap: 7px !important;
  border-radius: 999px !important; border: 1px solid rgba(0,159,152,.14) !important; background: var(--turquoise-soft) !important; color: #536781 !important; font-size: 14px !important; font-weight: 650 !important;
}
.sg-journey-field__chip iconify-icon { font-size: 16px !important; color: var(--turquoise-primary) !important; }
.sg-journey-clear { width: 44px !important; height: 44px !important; background: transparent !important; color: #7d8da3 !important; }
.sg-journey-clear iconify-icon {
  width: 34px !important; height: 34px !important; display: grid !important; place-items: center !important; border-radius: 999px !important;
  background: rgba(232,238,245,.86) !important; box-shadow: inset 0 0 0 1px rgba(7,26,51,.08) !important;
}
.sg-journey-clear:hover { background: transparent !important; }
.sg-journey__sep-line { background: var(--border-subtle) !important; }
.sg-journey--composer .sg-journey__swap {
  right: 21px !important; width: 54px !important; height: 54px !important; font-size: 25px !important; color: var(--navy-primary) !important;
  border: 1px solid var(--border-subtle) !important; box-shadow: 0 12px 26px rgba(7,26,51,.09), 0 2px 8px rgba(7,26,51,.05) !important;
  transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease !important;
}
.sg-journey--composer .sg-journey__swap:active:not(:disabled) { transform: translateY(-50%) scale(.97) !important; }

.sg-access-row--composer { min-height: 78px !important; padding: 16px 22px !important; border-top: 1px solid var(--border-subtle) !important; border-bottom: 0 !important; }
.sg-access-row--composer .sg-access-row__label { gap: 14px !important; }
.sg-access-row--composer .sg-access-row__icon {
  width: 44px !important; height: 44px !important; display: grid !important; place-items: center !important; border-radius: 999px !important;
  background: var(--turquoise-soft) !important; color: var(--turquoise-primary) !important; font-size: 24px !important; box-shadow: inset 0 0 0 1px rgba(0,159,152,.12) !important;
}
.sg-access-row--composer .sg-access-row__title { font-size: 18px !important; font-weight: 750 !important; line-height: 1.2 !important; color: var(--text-primary) !important; }
.sg-access-row--composer .sg-access-row__desc { font-size: 15px !important; line-height: 1.35 !important; color: var(--text-secondary) !important; }
.sg-composer .sg-toggle { width: 56px !important; height: 34px !important; border-radius: 999px !important; background: #c8d5e6 !important; }
.sg-composer .sg-toggle__thumb { top: 4px !important; left: 4px !important; width: 26px !important; height: 26px !important; }
.sg-composer .sg-toggle.is-on { background: var(--turquoise-primary) !important; }
.sg-composer .sg-toggle.is-on .sg-toggle__thumb { transform: translateX(22px) !important; }

.sg-composer__action { padding: 24px 22px 22px !important; gap: 12px !important; }
.sg-composer .sg-calc-btn {
  min-height: 62px !important; border-radius: 17px !important; padding: 0 24px !important; justify-content: center !important; position: relative !important;
  font-family: "Manrope", "Inter", system-ui, sans-serif !important; font-size: 18px !important; font-weight: 750 !important; background: var(--navy-primary) !important; color: #fff !important;
}
.sg-composer .sg-calc-btn:disabled { min-height: 62px !important; background: var(--disabled-surface) !important; color: var(--disabled-text) !important; }
.sg-calc-btn__arrow { position: absolute !important; right: 24px !important; font-size: 25px !important; }
.sg-form-hint { margin: 0 !important; font-size: 14px !important; line-height: 1.35 !important; font-weight: 500 !important; color: #52647f !important; text-align: center !important; }

.sg-quick-section { margin: 0 0 34px !important; }
.sg-quick-section__title { font-family: "Manrope", "Inter", system-ui, sans-serif !important; font-size: 21px !important; font-weight: 750 !important; line-height: 1.2 !important; color: var(--navy-primary) !important; margin: 0 0 22px !important; }
.sg-quick-scroll { gap: 14px !important; margin: 0 -26px !important; padding: 0 26px 8px !important; scroll-padding-inline: 26px !important; overscroll-behavior-inline: contain !important; }
.sg-quick-card {
  width: 132px !important; min-height: 180px !important; padding: 26px 12px 20px !important; gap: 12px !important; border-radius: 22px !important;
  background: var(--surface) !important; border: 1px solid rgba(220,229,239,.90) !important; box-shadow: 0 16px 36px rgba(7,26,51,.07), 0 2px 8px rgba(7,26,51,.04) !important;
}
.sg-quick-card__icon-wrap {
  width: 58px !important; height: 58px !important; font-size: 42px !important; border-radius: 999px !important;
  background: radial-gradient(circle, rgba(0,159,152,.10) 0%, rgba(0,159,152,.04) 62%, transparent 70%) !important; color: var(--turquoise-primary) !important;
}
.sg-quick-card__name { font-size: 17px !important; font-weight: 750 !important; line-height: 1.18 !important; letter-spacing: -.025em !important; color: var(--text-primary) !important; }
.sg-quick-card__sub { font-size: 14px !important; line-height: 1.35 !important; color: var(--text-secondary) !important; }

.sg-planning .sg-brandbar { animation: sg-fade-in 180ms ease both !important; }
.sg-planning .sg-airport-ctx { animation: sg-fade-in 190ms ease both 25ms !important; }
.sg-planning .sg-heading-region { animation: sg-fade-up 230ms ease both 55ms !important; }
.sg-planning .sg-composer { animation: sg-fade-up 250ms ease both 95ms !important; }
.sg-planning .sg-quick-section { animation: sg-fade-up 230ms ease both 135ms !important; }

@media (max-width: 380px) {
  .sg-brandbar { padding-left: 18px !important; padding-right: 18px !important; }
  .sg-brandbar__logo { width: 46px !important; height: 46px !important; }
  .sg-brandbar__left { gap: 13px !important; }
  .sg-help-btn { width: 48px !important; height: 48px !important; }
  .sg-airport-ctx, .sg-heading-region { padding-left: 18px !important; padding-right: 18px !important; }
  .sg-airport-ctx__text { font-size: 16px !important; }
  .sg-heading-region { padding-top: 48px !important; }
  .sg-heading { font-size: clamp(40px, 11.4vw, 44px) !important; }
  .sg-heading-sub { font-size: 17px !important; }
  .sg-planning .sg-planning-scroll { padding-left: 18px !important; padding-right: 18px !important; padding-top: 34px !important; }
  .sg-journey--composer .sg-journey-field { min-height: 106px !important; }
  .sg-journey--composer .sg-journey-field__value { font-size: 21px !important; }
  .sg-journey--composer .sg-journey-field__value.is-ph { font-size: 19px !important; }
  .sg-quick-scroll { margin-left: -18px !important; margin-right: -18px !important; padding-left: 18px !important; padding-right: 18px !important; scroll-padding-inline: 18px !important; }
  .sg-quick-card { width: 124px !important; min-height: 172px !important; }
}

@media (min-width: 431px) {
  .sg-brandbar, .sg-airport-ctx, .sg-heading-region, .sg-planning .sg-planning-scroll, .sg-planning .sg-planning-main { max-width: 520px !important; }
  .sg-brandbar, .sg-airport-ctx, .sg-heading-region { padding-left: 28px !important; padding-right: 28px !important; }
  .sg-planning .sg-planning-scroll { padding-left: 28px !important; padding-right: 28px !important; }
  .sg-quick-scroll { margin-left: -28px !important; margin-right: -28px !important; padding-left: 28px !important; padding-right: 28px !important; scroll-padding-inline: 28px !important; }
  .sg-quick-card { width: 136px !important; }
}

@media (min-height: 900px) {
  .sg-heading-region { padding-top: 58px !important; }
  .sg-planning .sg-planning-scroll { padding-top: 42px !important; }
}

/* ============================================================
   PLANNING HOME — FINAL REFERENCE-FIDELITY PASS  (v7)
   ============================================================ */

/* в”Ђв”Ђ 1. Body / app shell: planning must scroll naturally в”Ђв”Ђв”Ђв”Ђ */
body:has(.sg-planning) { overflow: auto !important; height: auto !important; }
#app:has(.sg-planning) {
  position: relative !important;
  overflow: visible !important;
  height: auto !important;
  min-height: 100dvh !important;
}
.sg-planning {
  overflow: visible !important;
  height: auto !important;
  min-height: 100dvh !important;
}

/* в”Ђв”Ђ 2. Background image: better framing, correct opacity в”Ђв”Ђв”Ђ */
.sg-hero-bg {
  height: 500px !important;
  min-height: 460px !important;
  max-height: 560px !important;
}
.sg-hero-bg__img {
  object-position: center 18% !important;
  opacity: 0.23 !important;
  filter: saturate(0.75) brightness(1.12) !important;
}
.sg-hero-bg__overlay {
  background: linear-gradient(
    180deg,
    rgba(245,248,252,0.14) 0%,
    rgba(245,248,252,0.40) 28%,
    rgba(245,248,252,0.76) 52%,
    #f5f8fc 72%,
    #f5f8fc 100%
  ) !important;
}

/* в”Ђв”Ђ 3. Element alignment wrapper в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-brandbar,
.sg-airport-ctx,
.sg-heading-region {
  width: 100% !important;
  max-width: 430px !important;
  margin-inline: auto !important;
}

/* в”Ђв”Ђ 4. Brand row в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-brandbar {
  padding: calc(var(--safe-top) + 20px) 22px 0 !important;
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  height: auto !important;
  position: relative !important;
  z-index: 3 !important;
}
.sg-brandbar__left { gap: 14px !important; }
.sg-brandbar__logo {
  width: 44px !important;
  height: 44px !important;
  border-radius: 12px !important;
  object-fit: cover !important;
  box-shadow: 0 2px 8px rgba(7,26,51,.14) !important;
}
.sg-brandbar__wordmark {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: clamp(25px, 6.8vw, 27px) !important;
  font-weight: 800 !important;
  letter-spacing: -0.035em !important;
  color: #061a35 !important;
  line-height: 1 !important;
}
.sg-help-btn {
  width: 48px !important;
  height: 48px !important;
  font-size: 23px !important;
  border-radius: 50% !important;
  background: #061a35 !important;
  color: #fff !important;
  box-shadow: 0 4px 14px rgba(6,26,53,.22) !important;
  flex-shrink: 0 !important;
}

/* в”Ђв”Ђ 5. Airport context в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-airport-ctx {
  position: relative !important;
  z-index: 3 !important;
  display: flex !important;
  align-items: center !important;
  gap: 8px !important;
  padding: 22px 22px 0 !important;
}
.sg-airport-ctx__icon {
  font-size: 17px !important;
  color: #009f98 !important;
  flex-shrink: 0 !important;
  line-height: 1 !important;
}
.sg-airport-ctx__text {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 16px !important;
  font-weight: 600 !important;
  color: #2a4062 !important;
  letter-spacing: -0.01em !important;
  white-space: nowrap !important;
}

/* в”Ђв”Ђ 6. Hero heading region в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-heading-region {
  position: relative !important;
  z-index: 3 !important;
  padding: 46px 22px 0 !important;
  max-width: 430px !important;
}
.sg-heading {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: clamp(44px, 12vw, 50px) !important;
  font-weight: 800 !important;
  line-height: 0.98 !important;
  letter-spacing: -0.043em !important;
  color: #061a35 !important;
  margin: 0 0 18px !important;
  max-width: 340px !important;
}
.sg-heading-sub {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 17px !important;
  font-weight: 400 !important;
  line-height: 1.48 !important;
  color: #667894 !important;
  max-width: 320px !important;
  margin: 0 !important;
}

/* в”Ђв”Ђ 7. Planning main / scroll в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-planning .sg-planning-main {
  position: relative !important;
  z-index: 3 !important;
  flex: 1 !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  overflow: visible !important;
  width: 100% !important;
}
.sg-planning .sg-planning-scroll {
  width: 100% !important;
  max-width: 430px !important;
  margin-inline: auto !important;
  padding: 34px 22px max(52px, var(--safe-bottom)) !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 0 !important;
  overflow: visible !important;
}

/* в”Ђв”Ђ 8. Route composer card в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-composer {
  width: 100% !important;
  background: #ffffff !important;
  border-radius: 26px !important;
  border: 1px solid rgba(7,26,51,0.08) !important;
  box-shadow:
    0 2px 8px rgba(7,26,51,0.05),
    0 12px 36px rgba(7,26,51,0.09) !important;
  overflow: hidden !important;
  margin-bottom: 32px !important;
}

/* в”Ђв”Ђ 9. Journey rail layout в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-journey--composer {
  display: flex !important;
  align-items: stretch !important;
  position: relative !important;
  border-bottom: none !important;
}
.sg-journey--composer .sg-journey__rail {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  padding: 0 !important;
  width: 56px !important;
  flex-shrink: 0 !important;
  gap: 0 !important;
}

/* Origin dot */
.sg-journey--composer .sg-journey__dot--origin {
  width: 22px !important;
  height: 22px !important;
  border-radius: 50% !important;
  background: #ffffff !important;
  border: 3px solid #009f98 !important;
  box-shadow: 0 0 0 4px rgba(0,159,152,0.12) !important;
  flex-shrink: 0 !important;
  margin-top: 36px !important;
}

/* Dashed connector */
.sg-journey__connector {
  flex: 1 !important;
  width: 2px !important;
  margin: 8px 0 !important;
  min-height: 56px !important;
  background: repeating-linear-gradient(
    to bottom,
    #9fb1c7 0, #9fb1c7 5px,
    transparent 5px, transparent 12px
  ) !important;
  opacity: 0.70 !important;
  transition: opacity 0.25s ease !important;
}
.sg-journey__rail.is-filled .sg-journey__connector {
  background: repeating-linear-gradient(
    to bottom,
    #009f98 0, #009f98 5px,
    transparent 5px, transparent 12px
  ) !important;
  opacity: 0.60 !important;
}

/* Destination dot */
.sg-journey--composer .sg-journey__dot--dest {
  width: 22px !important;
  height: 22px !important;
  border-radius: 50% !important;
  background: #b5c7da !important;
  border: 5px solid #edf3f8 !important;
  box-shadow: none !important;
  flex-shrink: 0 !important;
  margin-bottom: 36px !important;
}

/* в”Ђв”Ђ 10. Journey field rows в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-journey--composer .sg-journey__fields {
  flex: 1 !important;
  min-width: 0 !important;
  display: flex !important;
  flex-direction: column !important;
}
.sg-journey--composer .sg-journey-field {
  display: flex !important;
  align-items: center !important;
  min-height: 100px !important;
  width: 100% !important;
  padding: 0 16px 0 0 !important;
  background: transparent !important;
  border: none !important;
  text-align: left !important;
  cursor: pointer !important;
  transition: background 0.12s ease !important;
  position: relative !important;
}
.sg-journey--composer .sg-journey-field:hover {
  background: rgba(245,248,252,0.65) !important;
}
.sg-journey-field__inner {
  flex: 1 !important;
  min-width: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  padding: 12px 8px 12px 0 !important;
  gap: 0 !important;
}
.sg-journey-field__label {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 14px !important;
  font-weight: 700 !important;
  color: #657792 !important;
  line-height: 1.15 !important;
  margin-bottom: 8px !important;
}
.sg-journey--composer .sg-journey-field__value {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 21px !important;
  font-weight: 700 !important;
  color: #071a33 !important;
  line-height: 1.18 !important;
  letter-spacing: -0.025em !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}
.sg-journey--composer .sg-journey-field__value.is-ph {
  font-size: 18px !important;
  font-weight: 400 !important;
  letter-spacing: -0.015em !important;
  color: #96a8bc !important;
}

/* Metadata chip */
.sg-journey-field__chip {
  display: inline-flex !important;
  align-items: center !important;
  align-self: flex-start !important;
  gap: 6px !important;
  margin-top: 10px !important;
  padding: 0 12px 0 10px !important;
  height: 30px !important;
  background: #e3f7f4 !important;
  color: #52637e !important;
  border: 1px solid rgba(0,159,152,0.14) !important;
  border-radius: 999px !important;
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 13px !important;
  font-weight: 600 !important;
  line-height: 1 !important;
  white-space: nowrap !important;
  max-width: min(200px, 82%) !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}
.sg-journey-field__chip iconify-icon {
  font-size: 14px !important;
  color: #009f98 !important;
  flex-shrink: 0 !important;
}

/* Clear X */
.sg-journey-clear {
  flex-shrink: 0 !important;
  align-self: center !important;
  width: 40px !important;
  height: 40px !important;
  border-radius: 50% !important;
  display: grid !important;
  place-items: center !important;
  background: transparent !important;
  color: #7d8da3 !important;
  cursor: pointer !important;
  transition: background 0.12s ease !important;
}
.sg-journey-clear iconify-icon {
  width: 32px !important;
  height: 32px !important;
  display: grid !important;
  place-items: center !important;
  border-radius: 50% !important;
  background: rgba(232,238,245,0.9) !important;
  box-shadow: inset 0 0 0 1px rgba(7,26,51,0.08) !important;
  font-size: 17px !important;
}
.sg-journey-clear:hover { background: transparent !important; }

/* Divider */
.sg-journey__divider {
  display: flex !important;
  align-items: center !important;
  position: relative !important;
  height: 0 !important;
  z-index: 1 !important;
}
.sg-journey__sep-line {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  height: 1px !important;
  background: rgba(7,26,51,0.07) !important;
  pointer-events: none !important;
}

/* в”Ђв”Ђ 11. Swap button в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-journey--composer .sg-journey__swap {
  position: absolute !important;
  right: 18px !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  width: 50px !important;
  height: 50px !important;
  border-radius: 50% !important;
  display: grid !important;
  place-items: center !important;
  background: #ffffff !important;
  border: 1px solid rgba(7,26,51,0.10) !important;
  box-shadow:
    0 2px 8px rgba(7,26,51,0.07),
    0 8px 20px rgba(7,26,51,0.07) !important;
  font-size: 22px !important;
  color: #071a33 !important;
  cursor: pointer !important;
  z-index: 2 !important;
  margin: 0 !important;
  transition: background 0.12s ease, box-shadow 0.12s ease !important;
}
.sg-journey--composer .sg-journey__swap:hover:not(:disabled) {
  background: #f0fdfa !important;
  border-color: rgba(0,159,152,0.30) !important;
  color: #009f98 !important;
  box-shadow: 0 4px 16px rgba(0,159,152,0.16) !important;
}
.sg-journey--composer .sg-journey__swap:active:not(:disabled) {
  transform: translateY(-50%) scale(0.96) !important;
}
.sg-journey--composer .sg-journey__swap:disabled {
  opacity: 0.26 !important;
  cursor: not-allowed !important;
}

/* в”Ђв”Ђ 12. Accessible route row в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-access-row--composer {
  display: flex !important;
  align-items: center !important;
  min-height: 72px !important;
  padding: 16px 20px !important;
  gap: 14px !important;
  border-top: 1px solid rgba(7,26,51,0.07) !important;
  border-bottom: 0 !important;
  transition: background 0.12s ease !important;
  cursor: pointer !important;
}
.sg-access-row--composer:hover { background: rgba(245,248,252,0.6) !important; }
.sg-access-row--composer .sg-access-row__label {
  display: flex !important;
  align-items: center !important;
  gap: 14px !important;
  flex: 1 !important;
  cursor: pointer !important;
  min-width: 0 !important;
}
.sg-access-row--composer .sg-access-row__icon {
  width: 42px !important;
  height: 42px !important;
  display: grid !important;
  place-items: center !important;
  border-radius: 50% !important;
  background: #e3f7f4 !important;
  color: #009f98 !important;
  font-size: 22px !important;
  box-shadow: inset 0 0 0 1px rgba(0,159,152,0.14) !important;
  flex-shrink: 0 !important;
  transition: color 0.2s ease !important;
}
.sg-access-row--composer .sg-access-row__text {
  display: flex !important;
  flex-direction: column !important;
  gap: 3px !important;
  min-width: 0 !important;
}
.sg-access-row--composer .sg-access-row__title {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 17px !important;
  font-weight: 700 !important;
  color: #071a33 !important;
  line-height: 1.2 !important;
}
.sg-access-row--composer .sg-access-row__desc {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 14px !important;
  font-weight: 400 !important;
  color: #667894 !important;
  line-height: 1.35 !important;
}

/* Toggle switch */
.sg-composer .sg-toggle {
  position: relative !important;
  flex-shrink: 0 !important;
  width: 52px !important;
  height: 30px !important;
  border-radius: 15px !important;
  background: #c5d2e3 !important;
  border: none !important;
  cursor: pointer !important;
  transition: background 0.2s ease !important;
}
.sg-composer .sg-toggle.is-on { background: #009f98 !important; }
.sg-composer .sg-toggle::before { display: none !important; }
.sg-composer .sg-toggle__thumb {
  position: absolute !important;
  top: 4px !important;
  left: 4px !important;
  width: 22px !important;
  height: 22px !important;
  border-radius: 50% !important;
  background: #ffffff !important;
  box-shadow: 0 1px 4px rgba(0,0,0,0.22) !important;
  transition: transform 0.2s ease !important;
}
.sg-composer .sg-toggle.is-on .sg-toggle__thumb {
  transform: translateX(22px) !important;
}

/* в”Ђв”Ђ 13. Calculate button в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-composer__action {
  padding: 20px 22px 24px !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 10px !important;
}
.sg-composer .sg-calc-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 10px !important;
  min-height: 60px !important;
  width: 100% !important;
  background: #061a35 !important;
  color: #ffffff !important;
  border-radius: 16px !important;
  border: none !important;
  cursor: pointer !important;
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 18px !important;
  font-weight: 700 !important;
  letter-spacing: -0.02em !important;
  position: relative !important;
  transition: background 0.12s ease, transform 0.12s ease, box-shadow 0.12s ease !important;
}
.sg-composer .sg-calc-btn:hover:not(:disabled) {
  background: #0d2a52 !important;
  box-shadow: 0 6px 22px rgba(6,26,53,0.30) !important;
}
.sg-composer .sg-calc-btn:active:not(:disabled) { transform: scale(0.99) !important; }
.sg-composer .sg-calc-btn:disabled {
  background: #e8eef5 !important;
  color: #8fa5bc !important;
  cursor: not-allowed !important;
  box-shadow: none !important;
  min-height: 60px !important;
}
.sg-calc-btn__arrow {
  position: absolute !important;
  right: 22px !important;
  font-size: 22px !important;
  opacity: 0.85 !important;
}
.sg-form-hint {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 13px !important;
  font-weight: 500 !important;
  color: #52647f !important;
  text-align: center !important;
  line-height: 1.4 !important;
  margin: 0 !important;
}
.sg-form-hint.is-warn { color: #c0392b !important; font-weight: 600 !important; }

/* в”Ђв”Ђ 14. Quick access section в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-quick-section { margin: 0 0 40px !important; }
.sg-quick-section__title {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 21px !important;
  font-weight: 750 !important;
  line-height: 1.2 !important;
  letter-spacing: -0.025em !important;
  color: #061a35 !important;
  margin: 0 0 18px !important;
}
.sg-quick-scroll {
  display: flex !important;
  gap: 12px !important;
  overflow-x: auto !important;
  overflow-y: visible !important;
  scroll-snap-type: x mandatory !important;
  -webkit-overflow-scrolling: touch !important;
  scrollbar-width: none !important;
  margin-left: -22px !important;
  margin-right: -22px !important;
  padding-left: 22px !important;
  padding-right: 22px !important;
  padding-bottom: 8px !important;
  padding-top: 2px !important;
  scroll-padding-inline: 22px !important;
  overscroll-behavior-inline: contain !important;
}
.sg-quick-scroll::-webkit-scrollbar { display: none !important; }
.sg-quick-card {
  flex-shrink: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: flex-start !important;
  gap: 10px !important;
  padding: 24px 10px 18px !important;
  width: 122px !important;
  min-height: 158px !important;
  background: #ffffff !important;
  border: 1px solid rgba(220,229,239,0.90) !important;
  border-radius: 20px !important;
  cursor: pointer !important;
  text-align: center !important;
  scroll-snap-align: start !important;
  box-shadow:
    0 2px 6px rgba(7,26,51,0.05),
    0 8px 22px rgba(7,26,51,0.06) !important;
  transition: background 0.12s ease, border-color 0.12s ease, transform 0.14s ease, box-shadow 0.14s ease !important;
}
.sg-quick-card:hover {
  background: #f0fdfa !important;
  border-color: rgba(0,159,152,0.24) !important;
  transform: translateY(-3px) !important;
  box-shadow: 0 6px 20px rgba(7,26,51,0.10) !important;
}
.sg-quick-card:active { transform: scale(0.97) !important; }
.sg-quick-card__icon-wrap {
  width: 52px !important;
  height: 52px !important;
  border-radius: 50% !important;
  background: radial-gradient(circle, rgba(0,159,152,0.11) 0%, rgba(0,159,152,0.04) 60%, transparent 70%) !important;
  display: grid !important;
  place-items: center !important;
  font-size: 36px !important;
  color: #009f98 !important;
  flex-shrink: 0 !important;
  line-height: 1 !important;
  box-shadow: none !important;
  transition: color 0.12s ease !important;
}
.sg-quick-card:hover .sg-quick-card__icon-wrap {
  background: radial-gradient(circle, rgba(0,159,152,0.18) 0%, rgba(0,159,152,0.07) 60%, transparent 70%) !important;
  color: #007f78 !important;
}
.sg-quick-card__name {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 15px !important;
  font-weight: 750 !important;
  line-height: 1.2 !important;
  letter-spacing: -0.02em !important;
  color: #071a33 !important;
  text-align: center !important;
  word-break: keep-all !important;
}
.sg-quick-card__sub {
  font-family: "Manrope", "Inter", system-ui, sans-serif !important;
  font-size: 13px !important;
  font-weight: 400 !important;
  line-height: 1.35 !important;
  color: #667894 !important;
  text-align: center !important;
}

/* в”Ђв”Ђ 15. Entrance animations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.sg-planning .sg-brandbar      { animation: sg-fade-in  180ms ease both !important; }
.sg-planning .sg-airport-ctx   { animation: sg-fade-in  190ms ease both 20ms !important; }
.sg-planning .sg-heading-region { animation: sg-fade-up 240ms ease both 50ms !important; }
.sg-planning .sg-composer      { animation: sg-fade-up  260ms ease both 90ms !important; }
.sg-planning .sg-quick-section { animation: sg-fade-up  240ms ease both 130ms !important; }

/* в”Ђв”Ђ 16. Responsive breakpoints в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
@media (max-width: 360px) {
  .sg-brandbar { padding-left: 16px !important; padding-right: 16px !important; }
  .sg-airport-ctx, .sg-heading-region { padding-left: 16px !important; padding-right: 16px !important; }
  .sg-airport-ctx { padding-top: 18px !important; }
  .sg-heading-region { padding-top: 40px !important; }
  .sg-heading { font-size: clamp(38px, 10.8vw, 44px) !important; }
  .sg-heading-sub { font-size: 16px !important; }
  .sg-planning .sg-planning-scroll { padding-left: 16px !important; padding-right: 16px !important; padding-top: 30px !important; }
  .sg-quick-scroll { margin-left: -16px !important; margin-right: -16px !important; padding-left: 16px !important; padding-right: 16px !important; }
  .sg-quick-card { width: 114px !important; min-height: 150px !important; }
  .sg-journey--composer .sg-journey-field { min-height: 92px !important; }
}

@media (min-width: 431px) {
  .sg-brandbar, .sg-airport-ctx, .sg-heading-region, .sg-planning .sg-planning-scroll, .sg-planning .sg-planning-main { max-width: 520px !important; }
  .sg-brandbar { padding-left: 28px !important; padding-right: 28px !important; }
  .sg-airport-ctx { padding-left: 28px !important; padding-right: 28px !important; }
  .sg-heading-region { padding-left: 28px !important; padding-right: 28px !important; }
  .sg-planning .sg-planning-scroll { padding-left: 28px !important; padding-right: 28px !important; }
  .sg-quick-scroll { margin-left: -28px !important; margin-right: -28px !important; padding-left: 28px !important; padding-right: 28px !important; scroll-padding-inline: 28px !important; }
  .sg-quick-card { width: 128px !important; }
}

@media (min-width: 640px) {
  .sg-planning { align-items: center !important; }
  .sg-brandbar, .sg-airport-ctx, .sg-heading-region, .sg-planning .sg-planning-scroll, .sg-planning .sg-planning-main { max-width: 540px !important; }
  .sg-quick-card { width: 132px !important; }
  .sg-hero-bg { left: 50% !important; transform: translateX(-50%) !important; max-width: 540px !important; }
}

@media (min-height: 900px) {
  .sg-heading-region { padding-top: 56px !important; }
  .sg-planning .sg-planning-scroll { padding-top: 40px !important; }
}
